{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<!-- Header START -->
{{ include('components/header.html.twig') }}






<section>
	<div class="container">
		<!-- Title -->
		<div class="row mb-4">
			<div class="col-lg-8 mx-auto text-center">
				<h2 class="fs-1">Admin board</h2>
				<p class="mb-0">Visualize the list of available sessions, bookings and messages</p>
			</div>
		</div>

		<!-- Tabs START -->
		<ul class="nav nav-pills nav-pills-bg-soft justify-content-sm-center mb-4 px-3" id="course-pills-tab" role="tablist">
			<!-- Tab item -->
			<li class="nav-item me-2 me-sm-5">
				<button class="nav-link mb-2 mb-md-0 active" id="course-pills-tab-1" data-bs-toggle="pill" data-bs-target="#course-pills-tabs-1" type="button" role="tab" aria-controls="course-pills-tabs-1" aria-selected="false">Available sessions</button>
			</li>
			<!-- Tab item -->
			<li class="nav-item me-2 me-sm-5">
				<button class="nav-link mb-2 mb-md-0" id="course-pills-tab-2" data-bs-toggle="pill" data-bs-target="#course-pills-tabs-2" type="button" role="tab" aria-controls="course-pills-tabs-2" aria-selected="false">List of bookings</button>
			</li>
			<!-- Tab item -->
			<li class="nav-item me-2 me-sm-5">
				<button class="nav-link mb-2 mb-md-0" id="course-pills-tab-3" data-bs-toggle="pill" data-bs-target="#course-pills-tabs-3" type="button" role="tab" aria-controls="course-pills-tabs-3" aria-selected="false">Messages</button>
			</li>
			
		</ul>
		<!-- Tabs END -->

		<!-- Tabs content START -->
		<div class="tab-content" id="course-pills-tabContent">
			<!-- Content START -->
			<div class="tab-pane fade show active" id="course-pills-tabs-1" role="tabpanel" aria-labelledby="course-pills-tab-1">
                    <div class="container">

                        <!-- Tabs content START -->
                        <div class="tab-content" id="course-pills-tabContent">
                             <div class=" card-body">
				<!-- Course table START -->
				<div class="table-responsive border-0 rounded-3">
					<!-- Table START -->
					<table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
						<!-- Table head -->
						<thead>
							<tr>
								<th scope="col" class="border-0 rounded-start">Session Name</th>
								<th scope="col" class="border-0">Session level</th>
								<th scope="col" class="border-0">Date </th>
								<th scope="col" class="border-0">Duration</th>
								<th scope="col" class="border-0 ">Description</th>
								<th scope="col" class="border-0 rounded-end">Action</th>

							</tr>
						</thead>

						<!-- Table body START -->
						<tbody>
							 {% for session in Sessions %}
							<!-- Table row -->
							<tr>
								<!-- Table data -->
								<td>
									<div class="d-flex align-items-center position-relative">
										<!-- Image -->
										{# <div class="w-60px">
											<img src="assets/images/courses/4by3/08.jpg" class="rounded" alt="">
										</div> #}
										<!-- Title -->
										<h6 class="table-responsive-title mb-0 ms-2">	
											<a href="#" class="stretched-link">{{ session.getName() }}</a>
										</h6>
									</div>
								</td>

								<td>
									<div class="d-flex align-items-center">
										{# <div class="avatar avatar-xs flex-shrink-0">
											<img class="avatar-img rounded-circle" src="assets/images/avatar/09.jpg" alt="avatar">
										</div> #}
										<div class="ms-2">
											<h6 class="mb-0 fw-light">{{ session.getLevel() }}</h6>
										</div>
									</div>
								</td>

                                <td>
									{{ session.date|date('d M Y') }}
								</td>

								<td>
									{{ session.getSessionDescription() }}
								</td>

								<td>{{ session.getDuration() }} minutes</td>

								<td>
                                    <a href="#" 
                                            class="btn btn-sm btn-success me-1 mb-1 mb-md-0" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#modal"
                                            data-id="{{ session.id }}"
                                            data-name="{{ session.name }}"
                                            data-level="{{ session.level }}"
                                            data-description="{{ session.sessionDescription }}"
                                            data-date="{{ session.date | date('Y-m-d') }}"
                                            data-duration="{{ session.duration }}">
                                                Edit
                                    </a>
                                    <button
                                        class="btn btn-danger btn-sm mb-0"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-id="{{ session.id }}"
                                        data-token="{{ csrf_token('delete_Session_' ~ session.id) }}"
                                                            >
                                        Delete
                                    </button>

								</td>
							</tr>
                                  {% else %}
                                    <li class="list-group-item">No sessions available</li>
                             {% endfor %}
                           
						</tbody>
					</table>
				</div>
			</div>

                        
                        </div>
                        <!-- Tabs content END -->
                    </div>
                
			</div>
			<!-- Content END -->

			<!-- Content START -->
			<div class="tab-pane fade" id="course-pills-tabs-2" role="tabpanel" aria-labelledby="course-pills-tab-2">
                      <div class=" card-body">
				<!-- Course table START -->
				<div class="table-responsive border-0 rounded-3">
					<!-- Table START -->
					<table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
						<!-- Table head -->
						<thead>
							<tr>
								<th scope="col" class="border-0 rounded-start">First Name</th>
								<th scope="col" class="border-0">Last Name</th>
								<th scope="col" class="border-0">email </th>
								<th scope="col" class="border-0">Phone number</th>
								<th scope="col" class="border-0 rounded-end">Action</th>
							</tr>
						</thead>

						<!-- Table body START -->
						<tbody>
							 {% for booking in bookings %}
							<!-- Table row -->
							<tr>
								<!-- Table data -->
								<td>
									<div class="d-flex align-items-center position-relative">
										<!-- Image -->
										<div class="w-60px">
											<img src="assets/images/courses/4by3/08.jpg" class="rounded" alt="">
										</div>
										<!-- Title -->
										<h6 class="table-responsive-title mb-0 ms-2">	
											<a href="#" class="stretched-link">{{ booking.getFirstName() }}</a>
										</h6>
									</div>
								</td>

								<td>
									<div class="d-flex align-items-center">
										<div class="avatar avatar-xs flex-shrink-0">
											<img class="avatar-img rounded-circle" src="assets/images/avatar/09.jpg" alt="avatar">
										</div>
										<div class="ms-2">
											<h6 class="mb-0 fw-light">{{ booking.getLastName() }}</h6>
										</div>
									</div>
								</td>

								<td>
									{{ booking.getUserEmail() }}
								</td>

								<td>{{ booking.getPhoneNumber() }}</td>

								<td>
									<a href="#" 
                                        class="btn btn-sm btn-success me-1  mb-md-0" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#modal2"
                                        data-id="{{ booking.id }}"
                                        data-first-name="{{ booking.firstName }}"
                                        data-last-name="{{ booking.lastName }}"
                                        data-email="{{ booking.userEmail }}"
                                        data-phone="{{ booking.phoneNumber }}">
                                            Edit
                                    </a>
								<button
                                    class="btn btn-danger btn-sm mb-0"
                                    data-bs-toggle="modal"
                                    data-bs-target="#deleteModal2"
                                    data-id="{{ booking.id }}"
                                    data-token="{{ csrf_token('delete_booking_' ~ booking.id) }}"
                                                        >
                                    Delete
                                </button>


                                        
								</td>
							</tr>
                                  {% else %}
                                    <li class="list-group-item">No bookings available</li>
                             {% endfor %}
                           
						</tbody>
					</table>
				</div>
			</div>
			</div>
			</div>
		</div>
		<!-- Tabs content END -->
	</div>
</section>



{# session modals #}
<div class="modal fade" id="modal" tabindex="-1" aria-labelledby="viewReviewLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- Modal header -->
                <div class="modal-header bg-dark">
                    <h5 class="modal-title text-white" id="viewReviewLabel">Edit session informations</h5>
                    <button type="button" class="btn btn-sm btn-light mb-0" data-bs-dismiss="modal" aria-label="Close"><i class="bi bi-x-lg"></i></button>
                </div>
                <!-- Modal body -->

                <form method="post" action="{{ path('admin_session_update') }}">
                    <div class="modal-body">
                        <input type="hidden" name="id" id="modalId">

                        <div class="mb-3">
                            <label>Session name</label>
                            <input type="text" id="modalSessionName" class="form-control" name="name">
                        </div>

                        <div class="mb-3">
                            <label>Level</label>
                            <input type="text" id="modalSessionLevel" class="form-control" name="level">
                        </div>

                        <div class="mb-3">
                            <label>Session date</label>
                            <input type="date" id="modalSessionDate" class="form-control" name="date" >
                        </div>

                        <div class="mb-3">
                            <label>Description</label>
                            <input type="text" id="modalSessionDescription" class="form-control" name="sessionDescription">
                        </div>
                        <div class="mb-3">
                            <label>Duration</label>
                            <input type="number" id="modalSessionDuration" class="form-control" name="duration">
                        </div>
                    </div>
                
                    <!-- Modal footer -->
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">
                                Save changes
                        </button>
                        <button type="button" class="btn btn-danger-soft my-0" data-bs-dismiss="modal">Close</button>
                    </div>

                </form>
            </div>
        </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-dark">
                <h5 class="modal-title text-white">
                    Are you sure you want to delete this session?
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="{{ path('admin_session_delete') }}">
                <div class="modal-body text-center">

                    <input type="hidden" name="id" id="modalId">
                    <input type="hidden" name="_token" id="deleteToken">

                    <button type="submit" class="btn btn-danger me-2">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                </div>
            </form>

        </div>
    </div>
</div> 


{# booking modals #}
<div class="modal fade" id="modal2" tabindex="-1" aria-labelledby="viewReviewLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <!-- Modal header -->
                <div class="modal-header bg-dark">
                    <h5 class="modal-title text-white" id="viewReviewLabel">Edit booking</h5>
                    <button type="button" class="btn btn-sm btn-light mb-0" data-bs-dismiss="modal" aria-label="Close"><i class="bi bi-x-lg"></i></button>
                </div>
                <!-- Modal body -->

                <form method="post" action="{{ path('admin_booking_update') }}">
                    <div class="modal-body">
                        <input type="hidden" name="id" id="modalId2">

                        <div class="mb-3">
                            <label>First Name</label>
                            <input type="text" id="modalFirstName" class="form-control" name="firstName">
                        </div>

                        <div class="mb-3">
                            <label>Last Name</label>
                            <input type="text" id="modalLastName" class="form-control" name="lastName">
                        </div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input type="email" id="modalEmail" class="form-control" name="userEmail">
                        </div>

                        <div class="mb-3">
                            <label>Phone</label>
                            <input type="text" id="modalPhone" class="form-control" name="phoneNumber">
                        </div>
                    </div>
                
                    <!-- Modal footer -->
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-success">
                                Save changes
                        </button>
                        <button type="button" class="btn btn-danger-soft my-0" data-bs-dismiss="modal">Close</button>
                    </div>

                </form>
            </div>
        </div>
</div>

<div class="modal fade" id="deleteModal2" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-dark">
                <h5 class="modal-title text-white">
                    Are you sure you want to delete this booking?
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="{{ path('admin_booking_delete') }}">
                <div class="modal-body text-center">

                    <input type="hidden" name="id" id="modal2DeleteId">
                    <input type="hidden" name="_token" id="modal2DeleteToken">

                    <button type="submit" class="btn btn-danger me-2">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                </div>
            </form>

        </div>
    </div>
</div>




<script>
    function openModal() {
        let modal = new bootstrap.Modal(document.getElementById('modal'));
        modal.show();
    }

    function closeModal() {
        let modalEl = document.getElementById('modal');
        let modal = bootstrap.Modal.getInstance(modalEl);
        modal.hide();
    }


    document.getElementById('modal').addEventListener('show.bs.modal', function (event) {

    const button = event.relatedTarget;

        document.getElementById('modalId').value = 
            button.getAttribute('data-id');

        document.getElementById('modalSessionName').value = 
            button.getAttribute('data-name');

        document.getElementById('modalSessionLevel').value =
            button.getAttribute('data-level');

        document.getElementById('modalSessionDate').value =
            button.getAttribute('data-date');

        document.getElementById('modalSessionDescription').value =
            button.getAttribute('data-description');

        document.getElementById('modalSessionDuration').value =
            button.getAttribute('data-duration');
    });
</script>

<script>

    document.getElementById('deleteModal').addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;

        document.getElementById('modalId').value = button.getAttribute('data-id');
        document.getElementById('deleteToken').value = button.getAttribute('data-token');
    });

    var deleteModal = document.getElementById('deleteModal');

    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;

        var sessionId = button.getAttribute('data-id');
        var csrfToken = button.getAttribute('data-token');

        var modalIdInput = deleteModal.querySelector('#modalId');
        var modalTokenInput = deleteModal.querySelector('#deleteToken');

        modalIdInput.value = sessionId;
        modalTokenInput.value = csrfToken;
    });

</script> 




<script>
    function openModal() {
        let modal = new bootstrap.Modal(document.getElementById('modal2'));
        modal.show();
    }

    function closeModal() {
        let modalEl = document.getElementById('modal2');
        let modal = bootstrap.Modal.getInstance(modalEl);
        modal.hide();
    }


    document.getElementById('modal2').addEventListener('show.bs.modal', function (event) {

    const button = event.relatedTarget;

        document.getElementById('modalId2').value = 
            button.getAttribute('data-id');

        document.getElementById('modalFirstName').value = 
            button.getAttribute('data-first-name');

        document.getElementById('modalLastName').value =
            button.getAttribute('data-last-name');

        document.getElementById('modalEmail').value =
            button.getAttribute('data-email');

        document.getElementById('modalPhone').value =
            button.getAttribute('data-phone');
    });
</script>

<script>

    document.getElementById('deleteModal2').addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;

        document.getElementById('modal2DeleteId').value = button.getAttribute('data-id');
        document.getElementById('modal2DeleteToken').value = button.getAttribute('data-token');
    });

    var deleteModal = document.getElementById('deleteModal2');

    deleteModal.addEventListener('show.bs.modal', function (event) {
        // Button that triggered the modal
        var button = event.relatedTarget;

        // Get data from button attributes
        var bookingId = button.getAttribute('data-id');
        var csrfToken = button.getAttribute('data-token');

        // Update hidden inputs in the modal
        var modalIdInput = deleteModal.querySelector('#modalId2');
        var modalTokenInput = deleteModal.querySelector('#deleteToken');

        modalIdInput.value = bookingId;
        modalTokenInput.value = csrfToken;
    });

</script>




<!-- Footer START -->
{{ include('components/footer.html.twig') }}
<!-- Footer END -->
{% endblock %}