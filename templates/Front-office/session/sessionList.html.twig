
{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<!-- Header START -->
{{ include('components/header.html.twig') }}


<main>

<section class="bg-primary bg-opacity-10 py-5">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="text-center">
                    <h1 class="mb-3"><span class="text-primary"> Available sessions</span></h1>
                    <p class="lead mb-3">Add new session </p>
                    {# <button type="button" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-1"></i> Add
                    </button> #}

                    <a href="{{ path('booking_create') }}" class="btn btn-primary">
                        <i class="bi bi-calendar-plus me-1"></i> Book session
                    </a>
                    
                </div>
         
            </div>
              
        </div>
    </div>
</section>



<section>
	<div class="container">

		<!-- Tabs content START -->
		<div class="tab-content" id="course-pills-tabContent">
			<!-- Content START -->
			<div class="tab-pane fade show active" id="course-pills-tabs-1" role="tabpanel" aria-labelledby="course-pills-tab-1">
				<div class="row g-4">
					<!-- Card item START -->
                        {% for session in Sessions %}

                            <div class="col-sm-6 col-lg-4 col-xl-3">
                                <div class="card shadow h-100">
                                    <!-- Image -->
                                    <img src="{{ asset('assets/images/courses/4by3/08.jpg') }}" class="card-img-top" alt="course image">
                                    <!-- Card body -->
                                    <div class="card-body pb-0">
                                        <!-- Badge and favorite -->
                                        <div class="d-flex justify-content-between mb-2">
                                            <a href="#" class="badge bg-purple bg-opacity-10 text-purple">{{ session.getLevel() }}</a>
                                            {# <a href="#" class="h6 mb-0"><i class="far fa-heart"></i></a> #}
                                        </div>
                                        <!-- Title -->
                                        <h5 class="card-title fw-normal"><a href="#">{{ session.getName() }}</a></h5>
                                        <p class="mb-2 text-truncate-2">{{ session.getSessionDescription() }}</p>
                                        <!-- Rating star -->

                                            <div class="list-inline-item h6 fw-light mb-0">{{ session.date|date('d M Y') }}</div>
                                      
                                    </div>
                                    <!-- Card footer -->
                                    <div class="card-footer pt-0 pb-3">
                                        <hr>
                                        <div class="d-flex justify-content-between">
                                            <span class="h6 fw-light mb-0"><i class="far fa-clock text-danger me-2"></i>{{ session.getDuration() }} minutes</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Card item END -->
                        {% endfor %}

				
				</div> <!-- Row END -->
			</div>
			<!-- Content END -->

		
		</div>
		<!-- Tabs content END -->
	</div>
</section>





</main>





<!-- Footer START -->
{{ include('components/footer.html.twig') }}
<!-- Footer END -->
{% endblock %}
