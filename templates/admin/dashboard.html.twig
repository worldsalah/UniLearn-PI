{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - Unilearn{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}

<!-- **************** MAIN CONTENT START **************** -->
<main>

<!-- =======================
Admin Dashboard START -->
<section class="pt-4">
    <div class="container">
        <div class="row">
            <!-- Left sidebar START -->
            <div class="col-lg-3">
                <!-- User profile START -->
                <div class="card shadow mb-4">
                    <div class="card-body text-center p-4">
                        <div class="avatar avatar-xl mb-3">
                            <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                        </div>
                        <h5 class="mb-1">Admin User</h5>
                        <p class="mb-2">System Administrator</p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="#" class="btn btn-sm btn-primary">Settings</a>
                        </div>
                    </div>
                </div>
                <!-- User profile END -->

                <!-- Navigation menu START -->
                <div class="card shadow">
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="{{ path('app_admin_dashboard') }}" class="list-group-item list-group-item-action active">
                                <i class="fas fa-tachometer-alt me-2"></i>Dashboard
                            </a>
                            <a href="{{ path('app_admin_student_index') }}" class="list-group-item list-group-item-action">
                                <i class="fas fa-user-graduate me-2"></i>Students (Freelancers)
                            </a>
                            <a href="{{ path('app_admin_product_index') }}" class="list-group-item list-group-item-action">
                                <i class="fas fa-box me-2"></i>Services
                            </a>
                            <a href="{{ path('app_admin_job_index') }}" class="list-group-item list-group-item-action">
                                <i class="fas fa-briefcase me-2"></i>Job Requests
                            </a>
                            <a href="{{ path('app_admin_order_index') }}" class="list-group-item list-group-item-action">
                                <i class="fas fa-shopping-cart me-2"></i>Orders
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Navigation menu END -->
            </div>

            <!-- Main content START -->
            <div class="col-lg-9">
                <!-- Welcome header START -->
                <div class="card shadow mb-4">
                    <div class="card-body p-4">
                        <h3 class="mb-1">Admin Dashboard</h3>
                        <p class="mb-0">Manage and monitor the entire platform.</p>
                    </div>
                </div>
                <!-- Welcome header END -->

                <!-- Stats START -->
                <div class="row g-4 mb-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="card card-hover-shadow border-0 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="icon-lg bg-primary bg-opacity-10 text-primary rounded-circle">
                                        <i class="fas fa-users"></i>
                                    </div>
                                    <span class="badge bg-success">+15%</span>
                                </div>
                                <h4 class="mb-0">{{ stats.students }}</h4>
                                <p class="mb-0 small text-muted">Freelancers</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card card-hover-shadow border-0 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="icon-lg bg-success bg-opacity-10 text-success rounded-circle">
                                        <i class="fas fa-book"></i>
                                    </div>
                                    <span class="badge bg-success">+22%</span>
                                </div>
                                <h4 class="mb-0">{{ stats.products }}</h4>
                                <p class="mb-0 small text-muted">Services</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card card-hover-shadow border-0 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="icon-lg bg-warning bg-opacity-10 text-warning rounded-circle">
                                        <i class="fas fa-chalkboard-teacher"></i>
                                    </div>
                                    <span class="badge bg-success">+8%</span>
                                </div>
                                <h4 class="mb-0">{{ stats.jobs }}</h4>
                                <p class="mb-0 small text-muted">Job Requests</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-3">
                        <div class="card card-hover-shadow border-0 h-100">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="icon-lg bg-info bg-opacity-10 text-info rounded-circle">
                                        <i class="fas fa-dollar-sign"></i>
                                    </div>
                                    <span class="badge bg-success">+28%</span>
                                </div>
                                <h4 class="mb-0">${{ stats.revenue|number_format(2) }}</h4>
                                <p class="mb-0 small text-muted">Total Sales</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Stats END -->

                <!-- Charts START -->
                <div class="row g-4 mb-4">
                    <div class="col-lg-8">
                        <div class="card shadow">
                            <div class="card-body p-4">
                                <h5 class="mb-4">Revenue Overview</h5>
                                <canvas id="revenueChart" height="100"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card shadow">
                            <div class="card-body p-4">
                                <h5 class="mb-4">User Distribution</h5>
                                <canvas id="userChart" height="200"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Charts END -->

                <!-- Recent activities START -->
                <div class="card shadow mb-4">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0">Recent Activities</h5>
                            <a href="#" class="btn btn-sm btn-primary">View All</a>
                        </div>
                        
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Action</th>
                                        <th>Details</th>
                                        <th>Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="{{ asset('assets/images/avatar/08.jpg') }}" class="rounded-circle me-2" width="30" alt="User">
                                                <div>
                                                    <h6 class="mb-0">Alex Johnson</h6>
                                                    <small class="text-muted">Student</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-success">Enrolled</span></td>
                                        <td>Web Development Bootcamp</td>
                                        <td>2 hours ago</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="{{ asset('assets/images/instructor/01.jpg') }}" class="rounded-circle me-2" width="30" alt="User">
                                                <div>
                                                    <h6 class="mb-0">John Doe</h6>
                                                    <small class="text-muted">Instructor</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-primary">Created</span></td>
                                        <td>New course: React Masterclass</td>
                                        <td>5 hours ago</td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="{{ asset('assets/images/avatar/09.jpg') }}" class="rounded-circle me-2" width="30" alt="User">
                                                <div>
                                                    <h6 class="mb-0">Maria Garcia</h6>
                                                    <small class="text-muted">Student</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-warning">Completed</span></td>
                                        <td>UI/UX Design Masterclass</td>
                                        <td>1 day ago</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!-- Recent activities END -->

                <!-- Quick actions START -->
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h5 class="mb-4">Quick Actions</h5>
                        
                        <div class="row g-3">
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center">
                                    <div class="icon-xl bg-primary bg-opacity-10 text-primary rounded-circle mb-2 mx-auto">
                                        <i class="fas fa-user-plus fa-2x"></i>
                                    </div>
                                    <h6 class="mb-1">Add User</h6>
                                    <p class="mb-2 small text-muted">Create new user account</p>
                                    <button class="btn btn-sm btn-primary">Add User</button>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center">
                                    <div class="icon-xl bg-success bg-opacity-10 text-success rounded-circle mb-2 mx-auto">
                                        <i class="fas fa-plus-circle fa-2x"></i>
                                    </div>
                                    <h6 class="mb-1">Add Course</h6>
                                    <p class="mb-2 small text-muted">Create new course</p>
                                    <button class="btn btn-sm btn-success">Add Course</button>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center">
                                    <div class="icon-xl bg-warning bg-opacity-10 text-warning rounded-circle mb-2 mx-auto">
                                        <i class="fas fa-chart-line fa-2x"></i>
                                    </div>
                                    <h6 class="mb-1">Generate Report</h6>
                                    <p class="mb-2 small text-muted">Create analytics report</p>
                                    <button class="btn btn-sm btn-warning">Generate</button>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center">
                                    <div class="icon-xl bg-info bg-opacity-10 text-info rounded-circle mb-2 mx-auto">
                                        <i class="fas fa-bell fa-2x"></i>
                                    </div>
                                    <h6 class="mb-1">Send Notification</h6>
                                    <p class="mb-2 small text-muted">Broadcast message</p>
                                    <button class="btn btn-sm btn-info">Send</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Quick actions END -->
            </div>
            <!-- Main content END -->
        </div>
    </div>
</section>
<!-- =======================
Admin Dashboard END -->

</main>
<!-- **************** MAIN CONTENT END **************** -->

{% include 'components/footer.html.twig' %}

<!-- Chart.js for admin dashboard -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Revenue Chart
const revenueCtx = document.getElementById('revenueChart').getContext('2d');
new Chart(revenueCtx, {
    type: 'line',
    data: {
        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
        datasets: [{
            label: 'Revenue',
            data: [30000, 35000, 32000, 40000, 38000, 45000],
            borderColor: 'rgb(75, 192, 192)',
            backgroundColor: 'rgba(75, 192, 192, 0.2)',
            tension: 0.1
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false
    }
});

// User Distribution Chart
const userCtx = document.getElementById('userChart').getContext('2d');
new Chart(userCtx, {
    type: 'doughnut',
    data: {
        labels: ['Students', 'Instructors', 'Admins'],
        datasets: [{
            data: [20000, 456, 222],
            backgroundColor: [
                'rgba(54, 162, 235, 0.8)',
                'rgba(255, 206, 86, 0.8)',
                'rgba(255, 99, 132, 0.8)'
            ]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false
    }
});
</script>
{% endblock %}
