{% extends 'admin/admin_base.html.twig' %}

{% block title %}Admin Dashboard - Unilearn{% endblock %}

{% block admin_content %}
<!-- Title -->
<div class="row">
    <div class="col-12 mb-3">
        <h1 class="h3 mb-2 mb-sm-0">Dashboard</h1>
    </div>
</div>

<!-- Counter boxes START -->
<div class="row g-4 mb-4">
    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-warning bg-opacity-15 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <!-- Digit -->
                <div>
                    <h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ stats.students }}" data-purecounter-delay="200">0</h2>
                    <span class="mb-0 h6 fw-light">Freelancers</span>
                </div>
                <!-- Icon -->
                <div class="icon-lg rounded-circle bg-warning text-white mb-0"><i class="fas fa-user-graduate fa-fw"></i></div>
            </div>
        </div>
    </div>

    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-purple bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <!-- Digit -->
                <div>
                    <h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ stats.products }}" data-purecounter-delay="200">0</h2>
                    <span class="mb-0 h6 fw-light">Services</span>
                </div>
                <!-- Icon -->
                <div class="icon-lg rounded-circle bg-purple text-white mb-0"><i class="fas fa-tv fa-fw"></i></div>
            </div>
        </div>
    </div>

    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-primary bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <!-- Digit -->
                <div>
                    <h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ stats.jobs }}" data-purecounter-delay="200">0</h2>
                    <span class="mb-0 h6 fw-light">Job Requests</span>
                </div>
                <!-- Icon -->
                <div class="icon-lg rounded-circle bg-primary text-white mb-0"><i class="fas fa-briefcase fa-fw"></i></div>
            </div>
        </div>
    </div>

    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-success bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <!-- Digit -->
                <div>
                    <div class="d-flex">
                        <h2 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="{{ stats.revenue }}" data-purecounter-delay="200">0</h2>
                        <span class="mb-0 h2 ms-1">$</span>
                    </div>
                    <span class="mb-0 h6 fw-light">Total Revenue</span>
                </div>
                <!-- Icon -->
                <div class="icon-lg rounded-circle bg-success text-white mb-0"><i class="bi bi-currency-dollar fa-fw"></i></div>
            </div>
        </div>
    </div>
</div>
<!-- Counter boxes END -->

<!-- Chart and Ticket START -->
<div class="row g-4 mb-4">

    <!-- Chart START -->
    <div class="col-xxl-8">
        <div class="card shadow h-100">

            <!-- Card header -->
            <div class="card-header p-4 border-bottom">
                <h5 class="card-header-title">Earnings Overview</h5>
            </div>

            <!-- Card body -->
            <div class="card-body">
                <!-- Apex chart -->
                <div id="ChartPayout"></div>
            </div>
        </div>
    </div>
    <!-- Chart END -->

    <!-- Recent Activities START -->
    <div class="col-xxl-4">
        <div class="card shadow h-100">
            <!-- Card header -->
            <div class="card-header border-bottom d-flex justify-content-between align-items-center p-4">
                <h5 class="card-header-title">Recent Activity</h5>
                <a href="#" class="btn btn-link p-0 mb-0">View all</a>
            </div>

            <!-- Card body START -->
            <div class="card-body p-4">

                <!-- Activity item START -->
                <div class="d-flex justify-content-between position-relative">
                    <div class="d-sm-flex">
                        <!-- Avatar -->
                        <div class="avatar avatar-md flex-shrink-0">
                            <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/09.jpg') }}" alt="avatar">
                        </div>
                        <!-- Info -->
                        <div class="ms-0 ms-sm-2 mt-2 mt-sm-0">
                            <h6 class="mb-0"><a href="#" class="stretched-link">Lori Stevens</a></h6>
                            <p class="mb-0 small">Joined as a new Freelancer</p>
                            <span class="small">2 hours ago</span>
                        </div>
                    </div>
                </div>
                <!-- Activity item END -->

                <hr><!-- Divider -->

                <!-- Activity item START -->
                <div class="d-flex justify-content-between position-relative">
                    <div class="d-sm-flex">
                        <!-- Avatar -->
                        <div class="avatar avatar-md flex-shrink-0">
                            <div class="avatar-img rounded-circle bg-purple bg-opacity-10">
                                <span class="text-purple position-absolute top-50 start-50 translate-middle fw-bold">DB</span>
                            </div>
                        </div>
                        <!-- Info -->
                        <div class="ms-0 ms-sm-2 mt-2 mt-sm-0">
                            <h6 class="mb-0"><a href="#" class="stretched-link">Dennis Barrett</a></h6>
                            <p class="mb-0 small">Purchased "Web Design Masterclass"</p>
                            <span class="small">5 hours ago</span>
                        </div>
                    </div>
                </div>
                <!-- Activity item END -->

                <hr><!-- Divider -->

                <!-- Activity item START -->
                <div class="d-flex justify-content-between position-relative">
                    <div class="d-sm-flex">
                        <!-- Avatar -->
                        <div class="avatar avatar-md flex-shrink-0">
                            <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/04.jpg') }}" alt="avatar">
                        </div>
                        <!-- Info -->
                        <div class="ms-0 ms-sm-2 mt-2 mt-sm-0">
                            <h6 class="mb-0"><a href="#" class="stretched-link">Billy Vasquez</a></h6>
                            <p class="mb-0 small">Posted a new Job Request</p>
                            <span class="small">9 hours ago</span>
                        </div>
                    </div>
                </div>
                <!-- Activity item END -->
                
            </div>
            <!-- Card body END -->
        </div>
    </div>
    <!-- Recent Activities END -->
</div>
<!-- Chart and Ticket END -->
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Payout Chart
    if (document.getElementById('ChartPayout')) {
        var options = {
            series: [{
                name: 'Revenue',
                data: [2900, 4000, 3500, 5100, 4900, 6200, 6900]
            }],
            chart: {
                height: 300,
                type: 'area',
                toolbar: {
                    show: false
                }
            },
            dataLabels: {
                enabled: false
            },
            stroke: {
                curve: 'smooth'
            },
            colors: ['#066ac9'],
            xaxis: {
                type: 'category',
                categories: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
            },
            tooltip: {
                x: {
                    format: 'dd/MM/yy HH:mm'
                },
            },
        };

        var chart = new ApexCharts(document.querySelector("#ChartPayout"), options);
        chart.render();
    }
</script>
{% endblock %}
