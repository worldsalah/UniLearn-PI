{% extends 'base.html.twig' %}

{% block title %}Manage Jobs - Admin{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}
<main>
    <section class="pt-4">
        <div class="container">
            <div class="row">
                <div class="col-12 mb-4">
                    <div class="d-sm-flex justify-content-between align-items-center">
                        <h1 class="h3 mb-2 mb-sm-0">Manage Job Requests</h1>
                        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-sm btn-secondary mb-0">Back to Dashboard</a>
                    </div>
                </div>
            </div>
            
            <div class="card shadow">
                 <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-nowrap">
                            <thead class="thead-light">
                                <tr>
                                    <th scope="col">Title</th>
                                    <th scope="col">Client</th>
                                    <th scope="col">Budget</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Posted</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for job in jobs %}
                                    <tr>
                                        <td><h6 class="mb-0">{{ job.title }}</h6></td>
                                        <td>{{ job.client.email }}</td>
                                        <td>${{ job.budget }}</td>
                                        <td>
                                            {% if job.status == 'open' %}<span class="badge bg-success">Open</span>
                                            {% elseif job.status == 'assigned' %}<span class="badge bg-warning">Assigned</span>
                                            {% else %}<span class="badge bg-secondary">Completed</span>{% endif %}
                                        </td>
                                        <td>{{ job.createdAt|date('d M Y') }}</td>
                                        <td>
                                            <form method="post" action="{{ path('app_admin_job_delete', {'id': job.id}) }}" onsubmit="return confirm('Are you sure?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.id) }}">
                                                <button class="btn btn-sm btn-danger-soft mb-0"><i class="fas fa-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center">No jobs found.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                 <div class="card-footer border-top text-center">
                    {{ knp_pagination_render(jobs) }}
                </div>
            </div>
        </div>
    </section>
</main>
{% include 'components/footer.html.twig' %}
{% endblock %}
