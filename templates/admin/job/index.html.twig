{% extends 'admin/admin_base.html.twig' %}

{% block title %}Manage Jobs - Admin{% endblock %}

{% block admin_content %}
<!-- Title -->
<div class="row">
    <div class="col-12 mb-3">
        <div class="d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Job Requests</h1>
            <a href="{{ path('app_admin_job_new') }}" class="btn btn-primary mb-0">Add New Job</a>
        </div>
    </div>
</div>

<div class="card bg-transparent">
    <!-- Card header START -->
    <div class="card-header bg-transparent border-bottom px-0">
        <!-- Search and select START -->
        <div class="row g-3 align-items-center justify-content-between">
            <!-- Search bar -->
            <div class="col-md-8">
                <form class="rounded position-relative">
                    <input class="form-control bg-transparent" type="search" placeholder="Search" aria-label="Search">
                    <button class="bg-transparent p-2 position-absolute top-50 end-0 translate-middle-y border-0 text-primary-hover text-reset" type="submit">
                        <i class="fas fa-search fs-6 "></i>
                    </button>
                </form>
            </div>
        </div>
        <!-- Search and select END -->
    </div>
    <!-- Card header END -->

    <!-- Card body START -->
    <div class="card-body px-0">
        <div class="table-responsive border-0">
            <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                <!-- Table head -->
                <thead>
                    <tr>
                        <th scope="col" class="border-0 rounded-start">Job Title</th>
                        <th scope="col" class="border-0">Client</th>
                        <th scope="col" class="border-0">Budget</th>
                        <th scope="col" class="border-0">Status</th>
                        <th scope="col" class="border-0 rounded-end">Action</th>
                    </tr>
                </thead>

                <!-- Table body START -->
                <tbody>
                    {% for job in jobs %}
                        <tr>
                            <!-- Table data -->
                            <td>
                                <h6 class="mb-0">{{ job.title }}</h6>
                                <span class="text-body small"><i class="fas fa-fw fa-calendar-alt me-1 mt-1"></i>{{ job.createdAt|date('d M Y') }}</span>
                            </td>

                            <!-- Table data -->
                            <td>{{ job.client.email }}</td>

                            <!-- Table data -->
                            <td>
                                <span class="h6 mb-0 fw-light">${{ job.budget }}</span>
                            </td>

                            <!-- Table data -->
                            <td>
                                {% if job.status == 'open' %}<span class="badge bg-success bg-opacity-10 text-success">Open</span>
                                {% elseif job.status == 'assigned' %}<span class="badge bg-warning bg-opacity-10 text-warning">Assigned</span>
                                {% else %}<span class="badge bg-secondary bg-opacity-10 text-secondary">Completed</span>{% endif %}
                            </td>

                            <!-- Table data -->
                            <td>
                                <a href="{{ path('app_admin_job_edit', {id: job.id}) }}" class="btn btn-sm btn-success-soft me-1" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                <form method="post" action="{{ path('app_admin_job_delete', {id: job.id}) }}" onsubmit="return confirm('Are you sure?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.id) }}">
                                    <button class="btn btn-sm btn-danger-soft" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center">No jobs found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <!-- Card body END -->

    <!-- Card footer START -->
    <div class="card-footer bg-transparent pt-0">
        <!-- Pagination -->
        <div class="d-sm-flex justify-content-between align-items-center">
            <!-- Content -->
            <p class="mb-0 text-center text-sm-start">Showing {{ jobs.currentPageNumber }} of {{ jobs.getTotalItemCount }}</p>
            <!-- Pagination -->
            {{ knp_pagination_render(jobs) }}
        </div>
    </div>
    <!-- Card footer END -->
</div>
{% endblock %}
