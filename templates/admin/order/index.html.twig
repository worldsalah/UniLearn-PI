{% extends 'base.html.twig' %}

{% block title %}Manage Orders - Admin{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}
<main>
    <section class="pt-4">
        <div class="container">
            <div class="row">
                <div class="col-12 mb-4">
                    <div class="d-sm-flex justify-content-between align-items-center">
                        <h1 class="h3 mb-2 mb-sm-0">Manage Orders</h1>
                        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-sm btn-secondary mb-0">Back to Dashboard</a>
                    </div>
                </div>
            </div>
            
            <div class="card shadow">
                 <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-nowrap">
                            <thead class="thead-light">
                                <tr>
                                    <th scope="col">Order ID</th>
                                    <th scope="col">Product</th>
                                    <th scope="col">Buyer</th>
                                    <th scope="col">Amount</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in orders %}
                                    <tr>
                                        <td>#{{ order.id }}</td>
                                        <td>{{ order.product.title }}</td>
                                        <td>{{ order.buyer.email }}</td>
                                        <td>${{ order.totalPrice }}</td>
                                        <td>
                                            {% if order.status == 'pending' %}<span class="badge bg-warning">Pending</span>
                                            {% elseif order.status == 'paid' %}<span class="badge bg-success">Paid</span>
                                            {% else %}<span class="badge bg-danger">Cancelled</span>{% endif %}
                                        </td>
                                        <td>{{ order.createdAt|date('d M Y') }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center">No orders found.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                 <div class="card-footer border-top text-center">
                    {{ knp_pagination_render(orders) }}
                </div>
            </div>
        </div>
    </section>
</main>
{% include 'components/footer.html.twig' %}
{% endblock %}
