<!-- Success/Error Alert -->
<div id="alertContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 1050;"></div>

<script>
// Alert function
function showAlert(message, type = 'success') {
    const alertHtml = `
        <div class="alert alert-${type} alert-dismissible fade show" role="alert">
            <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    const alertContainer = document.getElementById('alertContainer');
    alertContainer.innerHTML = alertHtml;
    
    // Auto dismiss after 3 seconds
    setTimeout(() => {
        const alert = alertContainer.querySelector('.alert');
        if (alert) {
            const bsAlert = new bootstrap.Alert(alert);
            bsAlert.close();
        }
    }, 3000);
}

// Add Quiz Form Handler
document.addEventListener('DOMContentLoaded', function() {
    console.log('DOM loaded, looking for addQuizForm...');
    
    const addQuizForm = document.getElementById('addQuizForm');
    console.log('addQuizForm found:', addQuizForm);
    
    if (addQuizForm) {
        addQuizForm.addEventListener('submit', function(e) {
            console.log('Form submitted!');
            e.preventDefault();
            
            const formData = new FormData(this);
            const data = {
                title: formData.get('title'),
                courseId: formData.get('courseId') || null,
                timeLimit: formData.get('timeLimit') || null,
                passingScore: formData.get('passingScore') || 70
            };
            
            console.log('Quiz data to send:', data);

            // Show loading state
            const submitBtn = this.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Creating...';
            submitBtn.disabled = true;

            console.log('Sending request to /admin/quiz/create...');
            
            fetch('/admin/quiz/create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(data)
            })
            .then(response => {
                console.log('Response received:', response);
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data);
                if (data.success) {
                    showAlert('Quiz created successfully! Redirecting...', 'success');
                    
                    // Redirect to edit page to add questions
                    setTimeout(() => {
                        window.location.href = `/admin/quiz/${data.quizId}/edit`;
                    }, 2000);
                } else {
                    showAlert(data.message || 'Failed to create quiz', 'danger');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showAlert('An error occurred while creating the quiz', 'danger');
            })
            .finally(() => {
                // Restore button state
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            });
        });
    } else {
        console.error('addQuizForm not found!');
    }
});
</script>
