<!-- Add Question Modal -->
<div class="modal fade" id="addQuestionModal" tabindex="-1" aria-labelledby="addQuestionModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-lg">
		<div class="modal-content">
			<div class="modal-header bg-primary text-white">
				<h5 class="modal-title" id="addQuestionModalLabel">Add New Question</h5>
				<button type="button" class="btn btn-sm btn-light mb-0" data-bs-dismiss="modal" aria-label="Close"><i class="bi bi-x-lg"></i></button>
			</div>
			<div class="modal-body">
				<form class="row text-start g-3" id="addQuestionForm">
					<div class="col-12">
						<label class="form-label">Question</label>
						<input class="form-control" type="text" name="question" placeholder="Write a question" required>
					</div>
					<div class="col-6">
						<label class="form-label">Option A</label>
						<input class="form-control" type="text" name="option1" placeholder="Write option A" required>
					</div>
					<div class="col-6">
						<label class="form-label">Option B</label>
						<input class="form-control" type="text" name="option2" placeholder="Write option B" required>
					</div>
					<div class="col-6">
						<label class="form-label">Option C</label>
						<input class="form-control" type="text" name="option3" placeholder="Write option C" required>
					</div>
					<div class="col-6">
						<label class="form-label">Option D</label>
						<input class="form-control" type="text" name="option4" placeholder="Write option D" required>
					</div>
					<div class="col-12">
						<label class="form-label">Correct Option</label>
						<select class="form-select" name="correctOption" required>
							<option value="">Select correct answer</option>
							<option value="A">Option A</option>
							<option value="B">Option B</option>
							<option value="C">Option C</option>
							<option value="D">Option D</option>
						</select>
					</div>
				</form>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="submit" form="addQuestionForm" class="btn btn-primary">Add Question</button>
			</div>
		</div>
	</div>
</div>

<!-- Success/Error Alert -->
<div id="alertContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 1050;"></div>

<script>
// Alert function
function showAlert(message, type = 'success') {
    const alertHtml = `
        <div class="alert alert-${type} alert-dismissible fade show" role="alert">
            <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    const alertContainer = document.getElementById('alertContainer');
    alertContainer.innerHTML = alertHtml;
    
    // Auto dismiss after 3 seconds
    setTimeout(() => {
        const alert = alertContainer.querySelector('.alert');
        if (alert) {
            const bsAlert = new bootstrap.Alert(alert);
            bsAlert.close();
        }
    }, 3000);
}

// Add Question Form Handler
document.getElementById('addQuestionForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const data = {
        quiz_id: {{ quiz.id|json_encode() }},
        question: formData.get('question'),
        option_a: formData.get('option1'),
        option_b: formData.get('option2'),
        option_c: formData.get('option3'),
        option_d: formData.get('option4'),
        correct_option: formData.get('correctOption')
    };

    console.log('Adding question:', data);

    fetch('/question/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        console.log('Add question response status:', response.status);
        console.log('Add question response ok:', response.ok);
        return response.json();
    })
    .then(data => {
        console.log('Add question response data:', data);
        
        if (data.success) {
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('addQuestionModal'));
            modal.hide();
            
            // Reset form
            this.reset();
            
            // Show success message
            showAlert('Question added successfully!', 'success');
            
            // Reload page to show updated questions
            setTimeout(() => location.reload(), 1500);
        } else {
            showAlert('Add failed: ' + (data.message || 'Unknown error'), 'danger');
        }
    })
    .catch(error => {
        console.error('Add question error:', error);
        showAlert('Add failed: ' + error.message, 'danger');
    });
});

// Edit Question Function
window.editQuestion = function(questionId) {
    // Get current question data from the table row
    const row = document.querySelector(`button[onclick*="${questionId}"]`).closest('tr');
    const questionText = row.querySelector('td:nth-child(2) strong').textContent;
    const optionA = row.querySelector('td:nth-child(3) div:nth-child(1)').textContent.replace('A. ', '');
    const optionB = row.querySelector('td:nth-child(3) div:nth-child(2)').textContent.replace('B. ', '');
    const optionC = row.querySelector('td:nth-child(3) div:nth-child(3)').textContent.replace('C. ', '');
    const optionD = row.querySelector('td:nth-child(3) div:nth-child(4)').textContent.replace('D. ', '');
    const correctOption = row.querySelector('td:nth-child(4) span').textContent;
    
    // Create edit modal HTML
    const modalHtml = `
        <div class="modal fade show" id="editModal" style="display: block; background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header" style="background: #ffc107; color: black; padding: 15px; border-radius: 8px 8px 0 0;">
                        <h5 class="modal-title">Edit Question</h5>
                        <button type="button" class="btn btn-sm btn-dark" onclick="document.getElementById('editModal').remove();" style="float: right;">×</button>
                    </div>
                    <div class="modal-body">
                        <form id="editForm">
                            <div class="mb-3">
                                <label>Question:</label>
                                <textarea class="form-control" id="editQuestion" rows="3" required>${questionText}</textarea>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label>Option A:</label>
                                    <input type="text" class="form-control" id="editOptionA" value="${optionA}" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label>Option B:</label>
                                    <input type="text" class="form-control" id="editOptionB" value="${optionB}" required>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label>Option C:</label>
                                    <input type="text" class="form-control" id="editOptionC" value="${optionC}" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label>Option D:</label>
                                    <input type="text" class="form-control" id="editOptionD" value="${optionD}" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label>Correct Option:</label>
                                <select class="form-select" id="editCorrectOption" required>
                                    <option value="A" ${correctOption === 'A' ? 'selected' : ''}>Option A</option>
                                    <option value="B" ${correctOption === 'B' ? 'selected' : ''}>Option B</option>
                                    <option value="C" ${correctOption === 'C' ? 'selected' : ''}>Option C</option>
                                    <option value="D" ${correctOption === 'D' ? 'selected' : ''}>Option D</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <button type="button" class="btn btn-secondary" onclick="document.getElementById('editModal').remove();">Cancel</button>
                                <button type="submit" class="btn btn-warning" onclick="updateQuestion(${questionId})">Update Question</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    `;
    
    // Add modal to page
    document.body.insertAdjacentHTML('beforeend', modalHtml);
};

// Update Question Function
window.updateQuestion = function(questionId) {
    const data = {
        question: document.getElementById('editQuestion').value,
        optionA: document.getElementById('editOptionA').value,
        optionB: document.getElementById('editOptionB').value,
        optionC: document.getElementById('editOptionC').value,
        optionD: document.getElementById('editOptionD').value,
        correctOption: document.getElementById('editCorrectOption').value
    };
    
    console.log('Updating question:', questionId, data);
    
    fetch(`/admin/question/${questionId}/update`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Remove modal
            document.getElementById('editModal').remove();
            
            // Show success message
            alert('Question updated successfully!');
            
            // Reload page
            setTimeout(() => location.reload(), 1000);
        } else {
            alert('Update failed: ' + (data.message || 'Unknown error'));
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Error: ' + error.message);
    });
};

// Delete Question Function
window.deleteQuestion = function(questionId) {
    if (confirm('Are you sure you want to delete this question?')) {
        fetch(`/admin/question/${questionId}/delete`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showAlert('Question deleted successfully!', 'success');
                // Reload page to show updated questions
                setTimeout(() => location.reload(), 1500);
            } else {
                showAlert(data.message || 'Failed to delete question', 'danger');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showAlert('An error occurred while deleting the question', 'danger');
        });
    }
};

// Edit Quiz Form Handler
document.getElementById('editQuizForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const data = {
        title: formData.get('title'),
        courseId: formData.get('courseId') || null
    };

    console.log('Submitting quiz update:', data);
    alert('Updating quiz to: ' + data.title);

    // Show loading state
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Updating...';
    submitBtn.disabled = true;

    fetch(`/admin/quiz/{{ quiz.id }}/update`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(data)
    })
    .then(response => {
        console.log('Update response status:', response.status);
        console.log('Update response ok:', response.ok);
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        
        return response.json();
    })
    .then(data => {
        console.log('Update response data:', data);
        
        if (data.success) {
            showAlert('Quiz updated successfully! Redirecting...', 'success');
            // Update quiz title in page header
            document.querySelector('h1.h3').textContent = data.title || document.querySelector('h1.h3').textContent;
            
            // Redirect to quizzes list after 2 seconds
            setTimeout(() => {
                window.location.href = '/admin-quizzes';
            }, 2000);
        } else {
            showAlert('Update failed: ' + (data.message || 'Unknown error'), 'danger');
        }
    })
    .catch(error => {
        console.error('Update error:', error);
        showAlert('Update failed: ' + error.message, 'danger');
    })
    .finally(() => {
        // Restore button state
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
    });
});

</script>
{% endblock %}
