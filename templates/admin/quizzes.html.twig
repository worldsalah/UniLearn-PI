<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm">
		<div class="modal-content">
			<div class="modal-header bg-danger text-white">
				<h5 class="modal-title" id="deleteConfirmModalLabel">Confirm Delete</h5>
				<button type="button" class="btn btn-sm btn-light mb-0" data-bs-dismiss="modal" aria-label="Close"><i class="bi bi-x-lg"></i></button>
			</div>
			<div class="modal-body text-center">
				<i class="bi bi-exclamation-triangle text-warning fs-1 mb-3"></i>
				<p class="mb-0">Are you sure you want to delete this quiz?</p>
				<p class="text-muted small mb-0" id="deleteQuizInfo"></p>
			</div>
			<div class="modal-footer justify-content-center">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
					<i class="bi bi-x-circle me-2"></i>No
				</button>
				<button type="button" class="btn btn-danger" id="confirmDeleteBtn">
					<i class="bi bi-trash me-2"></i>Yes
				</button>
			</div>
		</div>
	</div>
</div>

<!-- Success/Error Alert -->
<div id="alertContainer" class="position-fixed top-0 end-0 p-3" style="z-index: 1050;"></div>

<script>
// Simple Delete Function
function confirmDelete(quizId, quizTitle) {
    if (confirm('Are you sure you want to delete this quiz: ' + quizTitle + '?')) {
        // Show loading
        alert('Deleting quiz...');
        
        // Send delete request
        fetch('/admin/quiz/' + quizId + '/delete', {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Quiz deleted successfully!');
                location.reload();
            } else {
                alert('Delete failed: ' + (data.message || 'Unknown error'));
            }
        })
        .catch(error => {
            alert('Error: ' + error.message);
        });
    }
}

// Delete Quiz Function - Define it first
function deleteQuiz(quizId, quizTitle) {
    alert('deleteQuiz function called! ID: ' + quizId + ', Title: ' + quizTitle);
    console.log('Delete function called with:', { quizId, quizTitle });
    
    // Store quiz ID for the confirm button
    const confirmBtn = document.getElementById('confirmDeleteBtn');
    if (confirmBtn) {
        confirmBtn.dataset.quizId = quizId;
        
        // Update modal content with quiz info
        const deleteInfo = document.getElementById('deleteQuizInfo');
        if (deleteInfo) {
            deleteInfo.textContent = `"${quizTitle}" and all its questions`;
        }
        
        // Show confirmation modal
        try {
            const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
            modal.show();
            console.log('Modal should be shown now');
        } catch (error) {
            console.error('Error showing modal:', error);
            alert('Error: Could not show confirmation modal. Please check console.');
        }
    } else {
        alert('Error: Confirm button not found');
    }
}

// Alert function
function showAlert(message, type = 'success') {
    const alertHtml = `
        <div class="alert alert-${type} alert-dismissible fade show" role="alert">
            <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-triangle'} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    const alertContainer = document.getElementById('alertContainer');
    alertContainer.innerHTML = alertHtml;
    
    // Auto dismiss after 3 seconds
    setTimeout(() => {
        const alert = alertContainer.querySelector('.alert');
        if (alert) {
            const bsAlert = new bootstrap.Alert(alert);
            bsAlert.close();
        }
    }, 3000);
}

// Handle confirm delete button click
document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
    const quizId = this.dataset.quizId;
    console.log('Confirm delete clicked for quiz ID:', quizId);
    
    if (!quizId) {
        console.error('No quiz ID found!');
        alert('Error: No quiz ID found');
        return;
    }
    
    // Close the modal
    try {
        const modal = bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal'));
        if (modal) {
            modal.hide();
        }
    } catch (error) {
        console.error('Error closing modal:', error);
    }
    
    // Show loading state
    showAlert('Deleting quiz...', 'info');
    
    // Perform delete operation
    console.log('Attempting to delete quiz:', quizId);
    
    // First try DELETE method
    fetch(`/admin/quiz/${quizId}/delete`, {
        method: 'DELETE',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => {
        console.log('DELETE Response received:', response);
        if (!response.ok) {
            throw new Error(`DELETE HTTP ${response.status}: ${response.statusText}`);
        }
        return response.json();
    })
    .then(data => {
        console.log('DELETE response:', data);
        if (data.success) {
            showAlert('Quiz deleted successfully!', 'success');
            setTimeout(() => {
                window.location.reload();
            }, 1500);
        } else {
            throw new Error(data.message || 'DELETE failed');
        }
    })
    .catch(error => {
        console.error('DELETE method failed, trying POST fallback:', error);
        
        // Try POST method as fallback
        const formData = new FormData();
        formData.append('_method', 'DELETE');
        
        return fetch(`/admin/quiz/${quizId}/delete`, {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => {
            console.log('POST Response received:', response);
            if (!response.ok) {
                throw new Error(`POST HTTP ${response.status}: ${response.statusText}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('POST response:', data);
            if (data.success) {
                showAlert('Quiz deleted successfully!', 'success');
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            } else {
                throw new Error(data.message || 'POST fallback failed');
            }
        });
    })
    .catch(error => {
        console.error('All delete methods failed:', error);
        showAlert('Delete failed: ' + error.message, 'danger');
    })
    .finally(() => {
        delete this.dataset.quizId;
    });
});

// Export Quizzes Function
window.exportQuizzes = function() {
    // Show loading state
    const exportBtn = document.querySelector('button[onclick*="exportQuizzes()"]');
    const originalText = exportBtn.innerHTML;
    exportBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Exporting...';
    exportBtn.disabled = true;
    
    // Trigger file download
    window.location.href = '/admin/quizzes/export';
    
    // Restore button state after a delay
    setTimeout(() => {
        exportBtn.innerHTML = originalText;
        exportBtn.disabled = false;
        showAlert('Report exported successfully! Save as HTML file and print to PDF if needed.', 'success');
    }, 2000);
};

// Character-by-character search filtering with immediate response
let searchTimeout;
let lastSearchTerm = '';

document.getElementById('searchForm').addEventListener('submit', function(e) {
    e.preventDefault();
    performSearch();
});

document.getElementById('searchInput').addEventListener('input', function() {
    const currentSearchTerm = this.value.trim();
    
    // Only search if the term has actually changed
    if (currentSearchTerm !== lastSearchTerm) {
        lastSearchTerm = currentSearchTerm;
        
        // Clear previous timeout
        clearTimeout(searchTimeout);
        
        // Very short debounce for immediate feel (50ms)
        searchTimeout = setTimeout(() => {
            performSearch();
        }, 50);
    }
});

// Also search on keyup for immediate response
document.getElementById('searchInput').addEventListener('keyup', function(e) {
    // Don't trigger on Enter key (form handles that)
    if (e.key !== 'Enter') {
        const currentSearchTerm = this.value.trim();
        
        if (currentSearchTerm !== lastSearchTerm) {
            lastSearchTerm = currentSearchTerm;
            clearTimeout(searchTimeout);
            
            // Very short debounce for keyup events (30ms)
            searchTimeout = setTimeout(() => {
                performSearch();
            }, 30);
        }
    }
});

// Also search on paste for immediate response
document.getElementById('searchInput').addEventListener('paste', function(e) {
    // Small delay to allow paste to complete
    setTimeout(() => {
        const currentSearchTerm = this.value.trim();
        if (currentSearchTerm !== lastSearchTerm) {
            lastSearchTerm = currentSearchTerm;
            clearTimeout(searchTimeout);
            performSearch();
        }
    }, 10);
});

function performSearch() {
    const searchTerm = document.getElementById('searchInput').value.trim();
    
    console.log('Performing search for:', searchTerm);
    
    // Show loading state
    const searchInput = document.getElementById('searchInput');
    const originalPlaceholder = searchInput.placeholder;
    searchInput.placeholder = 'Filtering...';
    
    const searchUrl = `/admin/quizzes/search?q=${encodeURIComponent(searchTerm)}`;
    console.log('Search URL:', searchUrl);
    
    fetch(searchUrl)
        .then(response => {
            console.log('Response status:', response.status);
            console.log('Response headers:', response.headers);
            return response.text();
        })
        .then(text => {
            console.log('Response text:', text);
            
            try {
                const data = JSON.parse(text);
                console.log('Parsed data:', data);
                
                if (data.success) {
                    updateQuizzesList(data.quizzes, data.allQuestions);
                    
                    // Show appropriate message based on search
                    if (searchTerm === '') {
                        showAlert('Showing all quizzes', 'info');
                    } else {
                        showAlert(`Filtered to ${data.quizzes.length} quiz${data.quizzes.length !== 1 ? 'zes' : ''} for "${searchTerm}"`, 'info');
                    }
                } else {
                    console.error('Search failed:', data);
                    showAlert(data.message || 'Search failed', 'danger');
                }
            } catch (e) {
                console.error('JSON parse error:', e);
                console.error('Response was:', text);
                showAlert('Invalid server response. Please check console.', 'danger');
            }
        })
        .catch(error => {
            console.error('Search error:', error);
            showAlert('An error occurred during search', 'danger');
        })
        .finally(() => {
            searchInput.placeholder = originalPlaceholder;
        });
}

function updateQuizzesList(quizzes, allQuestions) {
    const quizzesContainer = document.querySelector('.col-12');
    
    if (quizzes.length === 0) {
        const searchTerm = document.getElementById('searchInput').value.trim();
        quizzesContainer.innerHTML = `
            <div class="text-center py-5">
                <i class="bi bi-search fs-1 text-muted mb-3"></i>
                <h4 class="text-muted">No Quizzes Found</h4>
                <p class="text-muted">No quizzes match your search criteria for "${searchTerm}".</p>
                <button class="btn btn-primary" onclick="clearSearch()">
                    <i class="bi bi-x-circle me-2"></i>Clear Search
                </button>
            </div>
        `;
        return;
    }
    
    let quizzesHtml = '';
    quizzes.forEach(quiz => {
        // Find questions for this quiz
        let quizQuestions = [];
        allQuestions.forEach(quizGroup => {
            if (quizGroup.quiz_id == quiz.id) {
                quizQuestions = quizGroup.questions;
            }
        });
        
        // Highlight matching text in title
        const searchTerm = document.getElementById('searchInput').value.trim();
        const highlightedTitle = highlightSearchTerm(quiz.title, searchTerm);
        
        quizzesHtml += `
            <div class="card border bg-transparent rounded-3 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-1">${highlightedTitle}</h4>
                            <span class="badge bg-primary">
                                ${quizQuestions.length} Questions
                            </span>
                            <span class="badge bg-success ms-2">Active</span>
                        </div>
                        <div>
                            <a href="/admin/quiz/${quiz.id}/edit" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a href="/admin/quiz/${quiz.id}/view" class="btn btn-sm btn-info me-1">
                                <i class="bi bi-eye"></i> View
                            </a>
                            <button class="btn btn-sm btn-danger" onclick="confirmDelete(${quiz.id}, '${quiz.title.replace(/'/g, "\\'")}')">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                    
                    <!-- Questions Section -->
                    ${quizQuestions.length > 0 ? `
                        <div class="mt-4">
                            <h5 class="mb-3">Questions Preview</h5>
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Question</th>
                                            <th>Options</th>
                                            <th>Correct Answer</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        ${quizQuestions.slice(0, 3).map(question => `
                                            <tr>
                                                <td>
                                                    <strong>${highlightSearchTerm(question.question ? question.question : 'No question text', searchTerm)}${question.question && question.question.length > 80 ? '...' : ''}</strong>
                                                </td>
                                                <td>
                                                    <div class="small">
                                                        <div>A. ${highlightSearchTerm(question.optionA ? question.optionA : 'N/A', searchTerm)}${question.optionA && question.optionA.length > 30 ? '...' : ''}</div>
                                                        <div>B. ${highlightSearchTerm(question.optionB ? question.optionB : 'N/A', searchTerm)}${question.optionB && question.optionB.length > 30 ? '...' : ''}</div>
                                                        <div>C. ${highlightSearchTerm(question.optionC ? question.optionC : 'N/A', searchTerm)}${question.optionC && question.optionC.length > 30 ? '...' : ''}</div>
                                                        <div>D. ${highlightSearchTerm(question.optionD ? question.optionD : 'N/A', searchTerm)}${question.optionD && question.optionD.length > 30 ? '...' : ''}</div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="badge bg-success">✓ Correct Answer: ${question.correctOption ? question.correctOption : 'N/A'}</span>
                                                </td>
                                            </tr>
                                        `).join('')}
                                    </tbody>
                                </table>
                            </div>
                            ${quizQuestions.length > 3 ? `
                                <div class="text-center mt-3">
                                    <small class="text-muted">And ${quizQuestions.length - 3} more questions...</small>
                                </div>
                            ` : ''}
                        </div>
                    ` : `
                        <div class="mt-4 text-center text-muted">
                            <p>No questions added yet.</p>
                        </div>
                    `}
                </div>
            </div>
        `;
    });
    
    quizzesContainer.innerHTML = quizzesHtml;
}

function highlightSearchTerm(text, searchTerm) {
    if (!searchTerm) return text;
    
    // Create case-insensitive regex
    const regex = new RegExp(`(${searchTerm.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    
    // Highlight matching text
    return text.replace(regex, '<mark class="bg-warning">$1</mark>');
}

function clearSearch() {
    document.getElementById('searchInput').value = '';
    location.reload(); // Reload to show all quizzes
}

// Add keyboard shortcuts
document.addEventListener('keydown', function(e) {
    // Ctrl/Cmd + K to focus search
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('searchInput').focus();
    }
    
    // Escape to clear search
    if (e.key === 'Escape') {
        const searchInput = document.getElementById('searchInput');
        if (searchInput.value.trim() !== '') {
            clearSearch();
        }
    }
});
</script>
{% endblock %}
