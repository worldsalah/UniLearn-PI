{% extends 'admin/admin_base.html.twig' %}

{% block title %}Student Details - Admin{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-12 mb-3">
        <div class="d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Student Details</h1>
            <a href="{{ path('app_admin_student_index') }}" class="btn btn-sm btn-secondary mb-0">Back to List</a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow">
            <div class="card-body text-center p-4">
                <div class="avatar avatar-xxl mb-3">
                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                </div>
                <h5 class="mb-1">{{ student.fullName }}</h5>
                <p class="mb-2">Student / Freelancer</p>
                <div class="d-flex justify-content-center gap-2 mb-3">
                    <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                </div>
                <ul class="list-group list-group-flush text-start">
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">Email:</span>
                        <span class="h6 mb-0">{{ student.user.email }}</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">Joined:</span>
                        <span class="h6 mb-0">{{ student.createdAt|date('d M Y') }}</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                        <span class="text-muted">Rating:</span>
                        <span class="h6 mb-0"><i class="fas fa-star text-warning me-1"></i>{{ student.rating }}</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
    
    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-header border-bottom">
                <h5 class="card-header-title">About Student</h5>
            </div>
            <div class="card-body">
                <p>No biography available for this student.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
