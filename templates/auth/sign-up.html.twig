{# filepath: /c:/Users/omark/OneDrive/Desktop/projectweb/Unilearn/templates/auth/sign-up.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Sign Up - Unilearn{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}

<!-- **************** MAIN CONTENT START **************** -->
<main>
    <section class="p-0 d-flex align-items-center position-relative overflow-hidden">
        <div class="container-fluid">
            <div class="row">

                <!-- LEFT -->
                <div class="col-12 col-lg-6 d-md-flex align-items-center justify-content-center bg-primary bg-opacity-10 vh-lg-100">
                    <div class="p-3 p-lg-5">
                        <div class="text-center">
                            <h2 class="fw-bold">Welcome to our largest community</h2>
                            <p class="mb-0 h6 fw-light">Let's learn something new today!</p>
                        </div>

                        <img src="{{ asset('assets/images/element/02.svg') }}" class="mt-5" alt="">

                        <div class="d-sm-flex mt-5 align-items-center justify-content-center">
                            <ul class="avatar-group mb-2 mb-sm-0">
                                <li class="avatar avatar-sm">
                                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                                </li>
                                <li class="avatar avatar-sm">
                                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/02.jpg') }}" alt="avatar">
                                </li>
                                <li class="avatar avatar-sm">
                                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/03.jpg') }}" alt="avatar">
                                </li>
                                <li class="avatar avatar-sm">
                                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/04.jpg') }}" alt="avatar">
                                </li>
                            </ul>
                            <p class="mb-0 h6 fw-light ms-0 ms-sm-3">4k+ Students joined us, now it's your turn.</p>
                        </div>
                    </div>
                </div>

                <!-- RIGHT -->
                <div class="col-12 col-lg-6 m-auto">
                    <div class="row my-5">
                        <div class="col-sm-10 col-xl-8 m-auto">

                            <span class="mb-0 fs-1">👋</span>
                            <h1 class="fs-2">Sign Up into Unilearn!</h1>
                            <p class="lead mb-4">Nice to see you! Please Sign up with your account.</p>

                            {# Flash messages #}
                            {% for message in app.flashes('success') %}
                                <div class="alert alert-success">{{ message }}</div>
                            {% endfor %}
                            {% for message in app.flashes('error') %}
                                <div class="alert alert-danger">{{ message }}</div>
                            {% endfor %}

                            <!-- FORM START -->
                            {{ form_start(registrationForm) }}

                            <!-- Full Name -->
                            <div class="mb-4">
                                <label for="{{ registrationForm.fullName.vars.id }}" class="form-label">Full Name *</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3">
                                        <i class="bi bi-person-fill"></i>
                                    </span>
                                    {{ form_widget(registrationForm.fullName, {
                                        attr: {
                                            class: 'form-control border-0 bg-light rounded-end ps-1',
                                            placeholder: 'Enter your full name'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.fullName) }}
                            </div>

                            <!-- Username -->
                            <div class="mb-4">
                                <label for="{{ registrationForm.username.vars.id }}" class="form-label">Username *</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3">
                                        <i class="bi bi-person"></i>
                                    </span>
                                    {{ form_widget(registrationForm.username, {
                                        attr: {
                                            class: 'form-control border-0 bg-light rounded-end ps-1',
                                            placeholder: 'Enter your username'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.username) }}
                            </div>

                            <!-- Email -->
                            <div class="mb-4">
                                <label for="{{ registrationForm.email.vars.id }}" class="form-label">Email address *</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3">
                                        <i class="bi bi-envelope-fill"></i>
                                    </span>
                                    {{ form_widget(registrationForm.email, {
                                        attr: {
                                            class: 'form-control border-0 bg-light rounded-end ps-1',
                                            placeholder: 'Enter your email'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.email) }}
                            </div>

                            <!-- Password -->
                            <div class="mb-4">
                                <label for="{{ registrationForm.password.first.vars.id }}" class="form-label">Password *</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    {{ form_widget(registrationForm.password.first, {
                                        attr: {
                                            class: 'form-control border-0 bg-light rounded-end ps-1',
                                            placeholder: 'Enter your password'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.password.first) }}
                            </div>

                            <!-- Confirm Password -->
                            <div class="mb-4">
                                <label for="{{ registrationForm.password.second.vars.id }}" class="form-label">Confirm Password *</label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light rounded-start border-0 text-secondary px-3">
                                        <i class="fas fa-lock"></i>
                                    </span>
                                    {{ form_widget(registrationForm.password.second, {
                                        attr: {
                                            class: 'form-control border-0 bg-light rounded-end ps-1',
                                            placeholder: 'Confirm your password'
                                        }
                                    }) }}
                                </div>
                                {{ form_errors(registrationForm.password.second) }}
                            </div>

                            <!-- Agree Terms -->
                            <div class="mb-4 form-check">
                                {{ form_widget(registrationForm.agreeTerms, {
                                    attr: { class: 'form-check-input' }
                                }) }}
                                {{ form_label(registrationForm.agreeTerms, null, { label_attr: { class: 'form-check-label' } }) }}
                                {{ form_errors(registrationForm.agreeTerms) }}
                            </div>

                            <!-- Button -->
                            <div class="d-grid">
                                <button class="btn btn-primary mb-0" type="submit">Sign Up</button>
                            </div>

                            {{ form_end(registrationForm) }}
                            <!-- FORM END -->

                            <!-- SOCIAL -->
                            <div class="row">
                                <div class="position-relative my-4">
                                    <hr>
                                    <p class="small position-absolute top-50 start-50 translate-middle bg-body px-5">Or</p>
                                </div>

                                <div class="col-xxl-6 d-grid">
                                    <a href="{{ path('connect_google') }}" class="btn bg-google mb-2 mb-xxl-0">
                                        <i class="fab fa-fw fa-google text-white me-2"></i>Signup with Google
                                    </a>
                                </div>

                                <div class="col-xxl-6 d-grid">
                                    <a href="#" class="btn bg-facebook mb-0">
                                        <i class="fab fa-fw fa-facebook-f me-2"></i>Signup with Facebook
                                    </a>
                                </div>
                            </div>

                            <div class="mt-4 text-center">
                                <span>Already have an account?
                                    <a href="{{ path('app_login') }}"> Sign in here</a>
                                </span>
                            </div>

                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</main>
<!-- **************** MAIN CONTENT END **************** -->

{% include 'components/footer.html.twig' %}
{% endblock %}