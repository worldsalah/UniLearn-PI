{% extends 'base.html.twig' %}

{% block title %}Course Detail Module - Unilearn{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}

<!-- **************** MAIN CONTENT START **************** -->
<main>

<!-- =======================
Course Detail Module START -->
<section class="pt-4">
    <div class="container">
        <div class="row">
            <!-- Left sidebar START -->
            <div class="col-lg-3">
                <!-- Course navigation -->
                <div class="card shadow sticky-top" style="top: 100px;">
                    <div class="card-body p-3">
                        <h6 class="mb-3">Course Content</h6>
                        <nav class="nav flex-column nav-pills">
                            <a class="nav-link active" href="#overview">Overview</a>
                            <a class="nav-link" href="#module1">Module 1: HTML & CSS</a>
                            <a class="nav-link" href="#module2">Module 2: JavaScript</a>
                            <a class="nav-link" href="#module3">Module 3: React</a>
                            <a class="nav-link" href="#module4">Module 4: Node.js</a>
                            <a class="nav-link" href="#module5">Module 5: Database</a>
                            <a class="nav-link" href="#module6">Module 6: Project</a>
                        </nav>
                    </div>
                </div>
            </div>
            
            <!-- Main content START -->
            <div class="col-lg-9">
                <!-- Course header -->
                <div class="card shadow mb-4">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h1 class="mb-2">Complete Web Development Bootcamp 2024</h1>
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge bg-primary bg-opacity-10 text-primary me-2">Development</span>
                                    <div class="text-warning me-2">
                                        <i class="fas fa-star"></i>
                                        <span>4.5</span>
                                    </div>
                                    <small class="text-muted">(2,345 reviews)</small>
                                </div>
                                <p class="mb-3 text-muted">Learn web development from scratch with HTML, CSS, JavaScript, React, Node.js and more.</p>
                                <div class="d-flex align-items-center">
                                    <img src="{{ asset('assets/images/avatar/01.jpg') }}" class="rounded-circle me-2" width="30" alt="Instructor">
                                    <div>
                                        <h6 class="mb-0 small">John Doe</h6>
                                        <p class="mb-0 small text-muted">Senior Developer</p>
                                    </div>
                                    <div class="ms-auto">
                                        <span class="text-muted small me-3">45,234 students</span>
                                        <span class="text-muted small">42 hours</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="text-end">
                                    <h3 class="mb-0">$89.99</h3>
                                    <span class="text-decoration-line-through text-muted">$199.99</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Course modules -->
                <div class="card shadow">
                    <div class="card-body p-4">
                        <!-- Module 1 -->
                        <div id="module1" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Module 1: HTML & CSS Fundamentals</h4>
                                <span class="badge bg-success">8 lessons • 3 hours</span>
                            </div>
                            
                            <div class="accordion" id="module1Accordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#lesson1-1">
                                            Lesson 1: Introduction to HTML
                                        </button>
                                    </h2>
                                    <div id="lesson1-1" class="accordion-collapse collapse show" data-bs-parent="#module1Accordion">
                                        <div class="accordion-body">
                                            <p>Learn the basics of HTML5 and semantic markup. Understand the structure of HTML documents and how to create well-formed web pages.</p>
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge bg-primary">Video</span>
                                                <span class="text-muted">15:30</span>
                                                <button class="btn btn-sm btn-outline-primary">Watch</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lesson1-2">
                                            Lesson 2: CSS Basics
                                        </button>
                                    </h2>
                                    <div id="lesson1-2" class="accordion-collapse collapse" data-bs-parent="#module1Accordion">
                                        <div class="accordion-body">
                                            <p>Master CSS fundamentals including selectors, properties, and responsive design principles.</p>
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge bg-primary">Video</span>
                                                <span class="text-muted">18:45</span>
                                                <button class="btn btn-sm btn-outline-primary">Watch</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Module 2 -->
                        <div id="module2" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Module 2: JavaScript Essentials</h4>
                                <span class="badge bg-warning">10 lessons • 5 hours</span>
                            </div>
                            
                            <div class="accordion" id="module2Accordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lesson2-1">
                                            Lesson 1: JavaScript Basics
                                        </button>
                                    </h2>
                                    <div id="lesson2-1" class="accordion-collapse collapse" data-bs-parent="#module2Accordion">
                                        <div class="accordion-body">
                                            <p>Learn JavaScript fundamentals including variables, data types, functions, and control flow.</p>
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge bg-primary">Video</span>
                                                <span class="text-muted">22:15</span>
                                                <button class="btn btn-sm btn-outline-primary">Watch</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Module 3 -->
                        <div id="module3" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Module 3: React Development</h4>
                                <span class="badge bg-info">12 lessons • 8 hours</span>
                            </div>
                            
                            <div class="accordion" id="module3Accordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lesson3-1">
                                            Lesson 1: React Introduction
                                        </button>
                                    </h2>
                                    <div id="lesson3-1" class="accordion-collapse collapse" data-bs-parent="#module3Accordion">
                                        <div class="accordion-body">
                                            <p>Introduction to React, components, state management, and the React ecosystem.</p>
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge bg-primary">Video</span>
                                                <span class="text-muted">25:30</span>
                                                <button class="btn btn-sm btn-outline-primary">Watch</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Module 4 -->
                        <div id="module4" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Module 4: Node.js Backend</h4>
                                <span class="badge bg-success">8 lessons • 6 hours</span>
                            </div>
                            
                            <div class="accordion" id="module4Accordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lesson4-1">
                                            Lesson 1: Node.js Basics
                                        </button>
                                    </h2>
                                    <div id="lesson4-1" class="accordion-collapse collapse" data-bs-parent="#module4Accordion">
                                        <div class="accordion-body">
                                            <p>Learn Node.js fundamentals, npm, and building RESTful APIs with Express.js.</p>
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge bg-primary">Video</span>
                                                <span class="text-muted">20:15</span>
                                                <button class="btn btn-sm btn-outline-primary">Watch</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Module 5 -->
                        <div id="module5" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Module 5: Database Integration</h4>
                                <span class="badge bg-danger">6 lessons • 4 hours</span>
                            </div>
                            
                            <div class="accordion" id="module5Accordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#lesson5-1">
                                            Lesson 1: SQL Basics
                                        </button>
                                    </h2>
                                    <div id="lesson5-1" class="accordion-collapse collapse" data-bs-parent="#module5Accordion">
                                        <div class="accordion-body">
                                            <p>Learn SQL fundamentals, database design, and working with both SQL and NoSQL databases.</p>
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="badge bg-primary">Video</span>
                                                <span class="text-muted">18:45</span>
                                                <button class="btn btn-sm btn-outline-primary">Watch</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Module 6 -->
                        <div id="module6" class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0">Module 6: Final Project</h4>
                                <span class="badge bg-primary">1 project • 6 hours</span>
                            </div>
                            
                            <div class="card border-0 bg-light">
                                <div class="card-body p-4">
                                    <h5 class="mb-3">Final Project: E-commerce Website</h5>
                                    <p class="mb-3">Build a complete e-commerce website using all the skills learned throughout the course.</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="badge bg-warning">Project</span>
                                        <span class="text-muted">6 hours</span>
                                        <button class="btn btn-sm btn-primary">Start Project</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Progress tracking -->
                        <div class="card border-0 bg-light">
                            <div class="card-body p-4">
                                <h5 class="mb-3">Your Progress</h5>
                                <div class="progress mb-3" style="height: 20px;">
                                    <div class="progress-bar bg-success" style="width: 25%"></div>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">25% Complete</span>
                                    <span class="text-muted">15 of 60 lessons</span>
                                </div>
                                <button class="btn btn-primary btn-sm">Continue Learning</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- =======================
Course Detail Module END -->

</main>
<!-- **************** MAIN CONTENT END **************** -->

{% include 'components/footer.html.twig' %}
{% endblock %}
