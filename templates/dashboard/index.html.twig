{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<!-- Header START -->
{{ include('components/header.html.twig') }}
<!-- Header END -->

<!-- **************** MAIN CONTENT START **************** -->
<main>
    <!-- =======================
Page Banner START -->
<section class="pt-8 pb-0">
	<div class="container">
		<div class="row">
			<div class="col-12">
				<div class="bg-primary bg-opacity-10 rounded-3 p-4 p-md-5">
					<h1 class="fs-2 mb-3">Welcome to Your Dashboard</h1>
					<p class="mb-0">Manage your courses, track progress, and access your learning materials all in one place.</p>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- =======================
Page Banner END -->

<!-- =======================
Dashboard content START -->
<section class="pt-5 pb-0">
	<div class="container">
		<div class="row g-4">
			<!-- Left sidebar START -->
			<div class="col-lg-3">
				<!-- User info -->
				<div class="card card-body shadow text-center mb-4">
					<!-- Avatar -->
					<div class="avatar avatar-xl mb-3">
						<img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
					</div>
					<h6 class="mb-0">Lori Ferguson</h6>
					<p class="small mb-3">example@gmail.com</p>
					<hr>
					<!-- User detail -->
					<div class="text-start">
						<p class="mb-2"><i class="bi bi-calendar fa-fw me-2"></i>Joined: January 2024</p>
						<p class="mb-0"><i class="bi bi-award fa-fw me-2"></i>Student</p>
					</div>
				</div>

				<!-- Navigation menu -->
				<div class="card card-body shadow">
					<ul class="nav nav-pills nav-pills-vertical">
						<li class="nav-item">
							<a class="nav-link active" href="#"><i class="bi bi-grid fa-fw me-2"></i>Dashboard</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="#"><i class="bi bi-book fa-fw me-2"></i>My Courses</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="#"><i class="bi bi-heart fa-fw me-2"></i>Wishlist</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="#"><i class="bi bi-star fa-fw me-2"></i>Reviews</a>
						</li>
						<li class="nav-item">
							<a class="nav-link" href="#"><i class="bi bi-gear fa-fw me-2"></i>Settings</a>
						</li>
					</ul>
				</div>
			</div>
			<!-- Left sidebar END -->

			<!-- Main content START -->
			<div class="col-lg-9">
				<!-- Statistics START -->
				<div class="row g-4 mb-4">
					<div class="col-sm-6 col-lg-3">
						<div class="card card-body shadow text-center">
							<h2 class="mb-0">12</h2>
							<p class="mb-0">Enrolled Courses</p>
						</div>
					</div>
					<div class="col-sm-6 col-lg-3">
						<div class="card card-body shadow text-center">
							<h2 class="mb-0">8</h2>
							<p class="mb-0">Completed Courses</p>
						</div>
					</div>
					<div class="col-sm-6 col-lg-3">
						<div class="card card-body shadow text-center">
							<h2 class="mb-0">45h</h2>
							<p class="mb-0">Learning Hours</p>
						</div>
					</div>
					<div class="col-sm-6 col-lg-3">
						<div class="card card-body shadow text-center">
							<h2 class="mb-0">3</h2>
							<p class="mb-0">Certificates</p>
						</div>
					</div>
				</div>
				<!-- Statistics END -->

				<!-- Recent courses START -->
				<div class="card card-body shadow mb-4">
					<h5 class="mb-3">Recent Courses</h5>
					<div class="row g-3">
						<!-- Course item -->
						<div class="col-md-6">
							<div class="d-flex align-items-center">
								<img src="{{ asset('assets/images/courses/4by3/01.jpg') }}" class="rounded-2" width="80" alt="course">
								<div class="ms-3">
									<h6 class="mb-1"><a href="#">Web Design for Beginners</a></h6>
									<div class="progress" style="height: 6px;">
										<div class="progress-bar bg-success" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
									</div>
									<small class="text-muted">75% Complete</small>
								</div>
							</div>
						</div>
						<!-- Course item -->
						<div class="col-md-6">
							<div class="d-flex align-items-center">
								<img src="{{ asset('assets/images/courses/4by3/02.jpg') }}" class="rounded-2" width="80" alt="course">
								<div class="ms-3">
									<h6 class="mb-1"><a href="#">JavaScript Advanced</a></h6>
									<div class="progress" style="height: 6px;">
										<div class="progress-bar bg-warning" role="progressbar" style="width: 45%" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100"></div>
									</div>
									<small class="text-muted">45% Complete</small>
								</div>
							</div>
						</div>
					</div>
				</div>
				<!-- Recent courses END -->

				<!-- Recent activity START -->
				<div class="card card-body shadow">
					<h5 class="mb-3">Recent Activity</h5>
					<ul class="list-group list-group-flush">
						<li class="list-group-item px-0">
							<div class="d-flex">
								<div class="flex-shrink-0">
									<div class="avatar avatar-sm bg-success bg-opacity-10 text-success rounded-circle">
										<i class="bi bi-play-circle"></i>
									</div>
								</div>
								<div class="flex-grow-1 ms-3">
									<h6 class="mb-1">Started new lesson</h6>
									<p class="mb-0 small">CSS Grid Layout - Web Design for Beginners</p>
									<span class="small text-muted">2 hours ago</span>
								</div>
							</div>
						</li>
						<li class="list-group-item px-0">
							<div class="d-flex">
								<div class="flex-shrink-0">
									<div class="avatar avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle">
										<i class="bi bi-award"></i>
									</div>
								</div>
								<div class="flex-grow-1 ms-3">
									<h6 class="mb-1">Completed course</h6>
									<p class="mb-0 small">HTML Basics - Certificate earned</p>
									<span class="small text-muted">Yesterday</span>
								</div>
							</div>
						</li>
					</ul>
				</div>
				<!-- Recent activity END -->

                <!-- Marketplace Orders START -->
				<div class="card card-body shadow mt-4">
					<h5 class="mb-3">Marketplace Orders</h5>
                    <div class="table-responsive border-0">
                        <table class="table table-dark-gradient-active table-hover align-middle p-4 mb-0">
                            <thead>
                                <tr>
                                    <th scope="col" class="border-0 rounded-start">Service</th>
                                    <th scope="col" class="border-0">Price</th>
                                    <th scope="col" class="border-0">Status</th>
                                    <th scope="col" class="border-0 rounded-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for order in orders %}
                                    <tr>
                                        <td>
                                            <h6 class="mb-0">{{ order.product.title }}</h6>
                                        </td>
                                        <td>{{ order.totalPrice }} $</td>
                                        <td>
                                            {% if order.status == 'paid' %}
                                                <span class="badge bg-success">Paid</span>
                                            {% elseif order.status == 'completed' %}
                                                <span class="badge bg-secondary">Completed</span>
                                            {% else %}
                                                <span class="badge bg-warning">{{ order.status }}</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if order.status == 'paid' %}
                                                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#rateModal{{ order.id }}">
                                                    Complete & Rate
                                                </button>

                                                <!-- Rate Modal -->
                                                <div class="modal fade" id="rateModal{{ order.id }}" tabindex="-1" aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <form action="{{ path('app_order_complete', {id: order.id}) }}" method="POST">
                                                                <div class="modal-header">
                                                                    <h5 class="modal-title">Rate Service</h5>
                                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                                </div>
                                                                <div class="modal-body">
                                                                    <div class="mb-3">
                                                                        <label class="form-label">Rating (1-5)</label>
                                                                        <select name="rating" class="form-select" required>
                                                                            <option value="5">5 Stars</option>
                                                                            <option value="4">4 Stars</option>
                                                                            <option value="3">3 Stars</option>
                                                                            <option value="2">2 Stars</option>
                                                                            <option value="1">1 Star</option>
                                                                        </select>
                                                                    </div>
                                                                    <div class="mb-3">
                                                                        <label class="form-label">Review</label>
                                                                        <textarea name="review" class="form-control" rows="3" placeholder="Tell others about your experience..."></textarea>
                                                                    </div>
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                                    <button type="submit" class="btn btn-primary">Submit Review</button>
                                                                </div>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            {% elseif order.status == 'completed' %}
                                                <span class="text-muted small">Rated {{ order.rating }} <i class="fas fa-star text-warning"></i></span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="text-center">You haven't purchased any services yet.</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
				</div>
				<!-- Marketplace Orders END -->
			</div>
			<!-- Main content END -->
		</div>
	</div>
</section>
<!-- =======================
Dashboard content END -->
</main>
<!-- **************** MAIN CONTENT END **************** -->

<!-- Footer START -->
{{ include('components/footer.html.twig') }}
<!-- Footer END -->
{% endblock %}
