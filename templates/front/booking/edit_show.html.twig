{# templates/front/booking/edit.html.twig #}
{% extends 'front/base.html.twig' %}

{% block title %}Modifier Réservation - Eduport{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-edit me-3"></i>Modifier ma Réservation</h1>
    </div>
</div>

<div class="container">
    <div class="mb-4">
        <a href="{{ path('front_booking_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            {{ form_label(form.userName) }}
                            {{ form_widget(form.userName) }}
                            {{ form_errors(form.userName) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.userEmail) }}
                            {{ form_widget(form.userEmail) }}
                            {{ form_errors(form.userEmail) }}
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="fas fa-save me-2"></i>Enregistrer
                            </button>
                            <a href="{{ path('front_booking_index') }}" class="btn btn-outline-secondary">
                                Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}


{# templates/front/booking/show.html.twig #}
{% extends 'front/base.html.twig' %}

{% block title %}Détails Réservation - Eduport{% endblock %}

{% block body %}
<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-eye me-3"></i>Détails de ma Réservation</h1>
    </div>
</div>

<div class="container">
    <div class="mb-4">
        <a href="{{ path('front_booking_index') }}" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Retour
        </a>
        <a href="{{ path('front_booking_edit', {id: booking.id}) }}" class="btn btn-warning">
            <i class="fas fa-edit me-2"></i>Modifier
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <h5>
                        <i class="fas fa-user text-primary me-2"></i>
                        {{ booking.userName }}
                    </h5>
                    <p class="text-muted">
                        <i class="fas fa-envelope me-2"></i>
                        {{ booking.userEmail }}
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">Sessions ({{ booking.sessions|length }})</div>
                <div class="card-body">
                    {% if booking.sessions is empty %}
                        <p class="text-muted">Aucune session</p>
                    {% else %}
                        {% for session in booking.sessions %}
                        <div class="mb-2">
                            <strong>{{ session.name }}</strong><br>
                            <small>{{ session.date|date('d/m/Y H:i') }}</small>
                        </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
