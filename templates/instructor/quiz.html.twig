    // Enhanced sort functionality for quizzes
    function sortQuizResults(sortBy) {
        const tbody = document.querySelector('#quizTable tbody');
        if (tbody) {
            const rows = Array.from(tbody.querySelectorAll('.quiz-row'));
            
            rows.sort(function(a, b) {
                let aValue, bValue;
                
                switch(sortBy) {
                    case 'name':
                        // Get quiz title from the first cell
                        aValue = a.querySelector('td:nth-child(2) strong')?.textContent?.trim() || '';
                        bValue = b.querySelector('td:nth-child(2) strong')?.textContent?.trim() || '';
                        return aValue.localeCompare(bValue);
                        
                    case 'date':
                        // Get creation date from the 5th cell
                        aValue = a.querySelector('td:nth-child(5)')?.textContent?.trim() || '';
                        bValue = b.querySelector('td:nth-child(5)')?.textContent?.trim() || '';
                        return new Date(aValue) - new Date(bValue);
                        
                    case 'score':
                        // Sort by number of questions (as "score")
                        aValue = a.querySelector('td:nth-child(2) .badge')?.textContent?.trim() || '0';
                        bValue = b.querySelector('td:nth-child(2) .badge')?.textContent?.trim() || '0';
                        
                        // Extract number from "X Questions"
                        const aNum = parseInt(aValue.split(' ')[0]) || 0;
                        const bNum = parseInt(bValue.split(' ')[0]) || 0;
                        return bNum - aNum; // Descending order (most questions first)
                        
                    default:
                        return 0;
                }
            });
            
            // Re-append sorted rows
            rows.forEach(row => {
                // Also move the corresponding questions row
                const quizId = row.getAttribute('data-quiz-id');
                const questionsRow = document.getElementById('questions-' + quizId);
                tbody.appendChild(row);
                if (questionsRow) {
                    tbody.appendChild(questionsRow);
                }
            });
        }
        
        console.log('Quizzes sorted by:', sortBy);
        updateQuizStats();
    }
    
