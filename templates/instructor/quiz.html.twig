    if (!questionText.trim()) {
        showAlert('Question text is required', 'warning');
        document.getElementById('editQuestionText').focus();
        return;
    }
    
    if (questionText.trim().length < 5) {
        showAlert('Question must be at least 5 characters long', 'warning');
        document.getElementById('editQuestionText').focus();
        return;
    }
    
    const formData = new FormData(form);
    const questionType = 'multiple'; // Since all questions are multiple choice
    
    let questionData = {
        questionId: questionId,
        quizId: quizId,
        question: questionText,
        type: questionType,
        points: formData.get('points')
    };
    
    // Add question type specific data
    if (questionType === 'multiple') {
        const option1 = document.querySelector('input[name="editOption1"]').value;
        const option2 = document.querySelector('input[name="editOption2"]').value;
        const option3 = document.querySelector('input[name="editOption3"]').value;
        const option4 = document.querySelector('input[name="editOption4"]').value;
        const correctOption = document.querySelector('input[name="editCorrectOption"]:checked')?.value;
        
        // Validate required options
        if (!option1.trim()) {
            showAlert('Option A is required', 'warning');
            document.querySelector('input[name="editOption1"]').focus();
            return;
        }
        if (option1.trim().length < 1) {
            showAlert('Option A must be at least 1 character long', 'warning');
            document.querySelector('input[name="editOption1"]').focus();
            return;
        }
        
        if (!option2.trim()) {
            showAlert('Option B is required', 'warning');
            document.querySelector('input[name="editOption2"]').focus();
            return;
        }
        if (option2.trim().length < 1) {
            showAlert('Option B must be at least 1 character long', 'warning');
            document.querySelector('input[name="editOption2"]').focus();
            return;
        }
        
        if (!correctOption) {
            showAlert('Please select the correct answer', 'warning');
            return;
        }
        
        // Ensure options C and D are not empty (entity requires them)
        const finalOptionC = option3.trim() || 'Option C';
        const finalOptionD = option4.trim() || 'Option D';
        
        questionData.optionA = option1;
        questionData.optionB = option2;
        questionData.optionC = finalOptionC;
        questionData.optionD = finalOptionD;
        questionData.correctOption = correctOption;
    }
    
    console.log('Updating question with ID:', questionId);
    console.log('Sending data:', questionData);
    
    // Send request to update question
    fetch(`/quiz/question/${questionId}/edit`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(questionData)
    })
    .then(response => {
        console.log('Response status:', response.status);
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        console.log('Response data:', data);
        if (data.success) {
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('editQuestionModal'));
            modal.hide();
            
            // Show success message
            showAlert('Question updated successfully!', 'success');
            
            // Reload page to show updated question
            setTimeout(() => location.reload(), 1500);
        } else {
            showAlert(data.message || 'Failed to update question', 'danger');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('An error occurred while updating the question: ' + error.message, 'danger');
    });
};

