// Show/Hide question type options
function showQuestionTypeOptions(type) {
    // Hide all option sections
    document.getElementById('multipleChoiceOptions').style.display = 'none';
    document.getElementById('trueFalseOptions').style.display = 'none';
    document.getElementById('shortAnswerOptions').style.display = 'none';
    
    // Show selected option section
    switch(type) {
        case 'multiple':
            document.getElementById('multipleChoiceOptions').style.display = 'block';
            break;
        case 'true_false':
            document.getElementById('trueFalseOptions').style.display = 'block';
            break;
        case 'short_answer':
            document.getElementById('shortAnswerOptions').style.display = 'block';
            break;
    }
}

// Handle question type change
document.addEventListener('DOMContentLoaded', function() {
    const questionTypeRadios = document.querySelectorAll('input[name="questionType"]');
    questionTypeRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            showQuestionTypeOptions(this.value);
        });
    });
});

// Add Question Function
window.addQuestion = function() {
    const form = document.getElementById('addQuestionForm');
    const quizId = document.getElementById('quizId').value;
    const questionType = document.querySelector('input[name="questionType"]:checked')?.value || 'multiple';
    
    // Get question text
    const questionText = document.getElementById('questionText').value;
    if (!questionText.trim()) {
        showAlert('Question text is required', 'danger');
        document.getElementById('questionText').focus();
        return;
    }
    
    let questionData = {
        quizId: quizId,
        question: questionText,
        type: questionType
    };
    
    // Add question type specific data
    switch(questionType) {
        case 'multiple':
            const option1 = document.querySelector('input[name="option1"]').value;
            const option2 = document.querySelector('input[name="option2"]').value;
            const option3 = document.querySelector('input[name="option3"]').value;
            const option4 = document.querySelector('input[name="option4"]').value;
            const correctOption = document.querySelector('input[name="correctOption"]:checked')?.value;
            
            // Validate required options
            if (!option1.trim()) {
                showAlert('Please enter Option A', 'warning');
                document.querySelector('input[name="option1"]').focus();
                return;
            }
            if (!option2.trim()) {
                showAlert('Please enter Option B', 'warning');
                document.querySelector('input[name="option2"]').focus();
                return;
            }
            
            // Validate that a correct option is selected
            if (!correctOption) {
                showAlert('Please select the correct answer', 'warning');
                return;
            }
            
            questionData.optionA = option1;
            questionData.optionB = option2;
            questionData.optionC = option3 || 'Option C';
            questionData.optionD = option4 || 'Option D';
            questionData.correctOption = correctOption;
            break;
        case 'true_false':
            const tfAnswer = document.querySelector('input[name="tfAnswer"]:checked')?.value;
            if (!tfAnswer) {
                showAlert('Please select True or False', 'warning');
                return;
            }
            questionData.correctAnswer = tfAnswer;
            break;
        case 'short_answer':
            const shortAnswer = document.getElementById('correctAnswer').value;
            if (!shortAnswer.trim()) {
                showAlert('Please enter the correct answer', 'warning');
                document.getElementById('correctAnswer').focus();
                return;
            }
            questionData.correctAnswer = shortAnswer;
            break;
    }
    
    console.log('Sending question data:', questionData);
    
    // Send request to add question
    fetch('/question/add', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(questionData)
    })
    .then(response => response.json())
    .then(data => {
        console.log('Response received:', data);
        if (data.success) {
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('addQuestionModal'));
            modal.hide();
            
            // Show success message
            showAlert('Question added successfully!', 'success');
            
            // Reload page to show updated quiz
            setTimeout(() => location.reload(), 1500);
        } else {
            showAlert(data.message || 'Failed to add question', 'danger');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('An error occurred while adding the question', 'danger');
    });
};
</script>

