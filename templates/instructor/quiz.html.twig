{% block javascripts %}
<script src="{{ asset('assets/vendor/choices/js/choices.min.js') }}"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Initialize Choices.js for sort dropdown
    try {
        const sortSelect = document.querySelector('.js-choice');
        if (sortSelect && !sortSelect.classList.contains('choices__input')) {
            const choices = new Choices(sortSelect, {
                searchEnabled: false,
                itemSelectText: '',
                allowHTML: false,
                classNames: {
                    containerOuter: 'choices',
                    containerInner: 'choices__inner',
                    input: 'choices__input',
                    inputCloned: 'choices__input--cloned',
                    list: 'choices__list',
                    listItems: 'choices__list--multiple',
                    listSingle: 'choices__list--single',
                    listDropdown: 'choices__list--dropdown',
                    item: 'choices__item',
                    itemSelectable: 'choices__item--selectable',
                    itemDisabled: 'choices__item--disabled',
                    itemChoice: 'choices__item--choice',
                    placeholder: 'choices__placeholder',
                    group: 'choices__group',
                    groupHeading: 'choices__heading',
                    button: 'choices__button',
                    activeState: 'is-active',
                    focusState: 'is-focused',
            openState: 'is-open',
            disabledState: 'is-disabled',
            highlightedState: 'is-highlighted',
            selectedState: 'is-selected',
            flippedState: 'is-flipped',
            loadingState: 'is-loading',
            noResults: 'has-no-results',
            noChoices: 'has-no-choices'
                }
            });
            
            // Add change event listener for sorting
            sortSelect.addEventListener('change', function(event) {
                const sortBy = event.detail.value || event.target.value;
                sortQuizResults(sortBy);
            });
            
            console.log('Choices.js initialized successfully');
        }
    } catch (error) {
        console.error('Error initializing Choices.js:', error);
        // Fallback to regular select if Choices.js fails
        const sortSelect = document.querySelector('.js-choice');
        if (sortSelect) {
            sortSelect.style.display = 'block';
            sortSelect.addEventListener('change', function(event) {
                const sortBy = event.target.value;
                sortQuizResults(sortBy);
            });
        }
    }

    // Alert notification function
    window.showAlert = function(message, type = 'info') {
        // Remove any existing alerts
        const existingAlert = document.querySelector('.custom-alert');
        if (existingAlert) {
            existingAlert.remove();
        }

        // Create alert element
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show custom-alert position-fixed`;
        alertDiv.style.cssText = `
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
            max-width: 500px;
        `;
        
        alertDiv.innerHTML = `
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;

        // Add to document
        document.body.appendChild(alertDiv);

        // Auto-remove after 5 seconds
        setTimeout(() => {
            if (alertDiv && alertDiv.parentNode) {
                alertDiv.remove();
            }
        }, 5000);

        // Handle manual close
        alertDiv.querySelector('.btn-close').addEventListener('click', function() {
            alertDiv.remove();
        });
    };

    // Search functionality for quizzes and student results
    const searchForm = document.getElementById('searchForm');
    const searchInput = document.getElementById('searchInput');
    
    if (searchForm && searchInput) {
        searchForm.addEventListener('submit', function(e) {
            e.preventDefault();
            performSearch();
        });
        
        searchInput.addEventListener('input', function() {
            performSearch();
        });
    }
    
    // Enhanced search functionality
    function performSearch() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
        
        // Search only in the active tab
        const activeTab = document.querySelector('.tab-pane.active');
        const quizRows = activeTab.querySelectorAll('.quiz-row');
        let visibleQuizCount = 0;
        
        quizRows.forEach(row => {
            const quizId = row.querySelector('td:nth-child(1)')?.textContent?.toLowerCase() || '';
            const title = row.querySelector('td:nth-child(2) strong')?.textContent?.toLowerCase() || '';
            const questions = row.querySelector('td:nth-child(3)')?.textContent?.toLowerCase() || '';
            const course = row.querySelector('td:nth-child(4)')?.textContent?.toLowerCase() || '';
            const date = row.querySelector('td:nth-child(5)')?.textContent?.toLowerCase() || '';
            
            const isVisible = quizId.includes(searchTerm) || 
                             title.includes(searchTerm) || 
                             questions.includes(searchTerm) || 
                             course.includes(searchTerm) || 
                             date.includes(searchTerm);
            
            row.style.display = isVisible ? '' : 'none';
            if (isVisible) visibleQuizCount++;
        });
        
        // Update quiz count badge
        const quizBadge = document.querySelector('.badge.bg-primary');
        if (quizBadge) {
            quizBadge.textContent = visibleQuizCount + ' Quizzes Found';
        }
        
        console.log('Quiz search performed for:', searchTerm, 'Quizzes found:', visibleQuizCount);
    }

    // Update quiz statistics
    function updateQuizStats() {
        const quizRows = document.querySelectorAll('#quizTable .quiz-row');
        const visibleQuizRows = Array.from(quizRows).filter(row => row.style.display !== 'none');
        
        // Calculate quiz statistics
        let totalQuestions = 0;
        let quizzesWithQuestions = 0;
        const quizzes = [];
        
        // Get quiz data from the page
        {% for quiz in quizzes %}
            quizzes.push({
                id: {{ quiz.id }},
                questions: {{ quiz.questions|length }},
                createdAt: '{{ quiz.createdAt|date('Y-m-d') }}'
            });
        {% endfor %}
        
        // Calculate statistics
        quizzes.forEach(quiz => {
            totalQuestions += quiz.questions;
            if (quiz.questions > 0) {
                quizzesWithQuestions++;
            }
        });
        
        const avgQuestions = quizzesWithQuestions > 0 ? Math.round(totalQuestions / quizzesWithQuestions) : 0;
        
        // Find latest quiz
        let latestQuiz = 'No Quiz';
        if (quizzes.length > 0) {
            const today = new Date().toISOString().split('T')[0];
            const sortedQuizzes = quizzes.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
            latestQuiz = sortedQuizzes[0].createdAt === today ? 'Today' : sortedQuizzes[0].createdAt;
        }
        
        // Update DOM elements
        document.getElementById('totalQuizzes').textContent = visibleQuizRows.length;
        document.getElementById('totalQuestions').textContent = totalQuestions;
        document.getElementById('avgQuestions').textContent = avgQuestions;
        document.getElementById('recentQuiz').textContent = latestQuiz;
    }

    // Update dynamic stats (legacy function for student results)
    function updateStats(visibleCount = null) {
        // For backward compatibility, call the quiz stats function
        updateQuizStats();
    }

    // Update dynamic stats
    function updateStats(visibleCount = null) {
        // Update quiz statistics
        updateQuizStats();
        
        // Update visible count
        const quizRows = document.querySelectorAll('#quizTable .quiz-row');
        const visibleQuizRows = Array.from(quizRows).filter(row => row.style.display !== 'none');
        const visibleCountElement = document.getElementById('visibleCount');
        if (visibleCountElement) {
            visibleCountElement.textContent = visibleQuizRows.length;
        }
    }

    function updateScoreStats(rows) {
        let scores = [];
        rows.forEach(row => {
            if (row.style.display === 'none') return;
            
            const scoreText = row.querySelector('td:nth-child(4) .badge')?.textContent?.trim() || '';
            const score = parseInt(scoreText.split('/')[0]) || 0;
            if (score > 0) scores.push(score);
        });
        
        if (scores.length > 0) {
            // Average score
            const avgScore = Math.round(scores.reduce((a, b) => a + b, 0) / scores.length);
            const avgElement = document.getElementById('avgScore');
            if (avgElement) avgElement.textContent = avgScore + '%';
            
            // Highest score
            const highScore = Math.max(...scores);
            const highElement = document.getElementById('highScore');
            if (highElement) highElement.textContent = highScore + '%';
        }
    }

    function updateActivityStats(rows) {
        let latestDate = null;
        rows.forEach(row => {
            if (row.style.display === 'none') return;
            
            const dateText = row.querySelector('td:nth-child(3)')?.textContent?.trim() || '';
            if (dateText) {
                const date = new Date(dateText);
                if (!latestDate || date > latestDate) {
                    latestDate = date;
                }
            }
        });
        
        const activityElement = document.getElementById('recentActivity');
        if (activityElement && latestDate) {
            const today = new Date();
            const diffTime = Math.abs(today - latestDate);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            
            if (diffDays === 0) {
                activityElement.textContent = 'Today';
            } else if (diffDays === 1) {
                activityElement.textContent = 'Yesterday';
            } else if (diffDays < 7) {
                activityElement.textContent = diffDays + ' days ago';
            } else {
                activityElement.textContent = latestDate.toLocaleDateString();
            }
        }
    }

    // Refresh results
    function refreshResults() {
        // Show loading state
        const refreshBtn = event.target;
        const originalHtml = refreshBtn.innerHTML;
        refreshBtn.innerHTML = '<i class="bi bi-arrow-clockwise me-1 spin"></i> Refreshing...';
        refreshBtn.disabled = true;
        
        // Simulate refresh (in real app, this would fetch new data from server)
        setTimeout(() => {
            // Show all quiz rows (reset any hidden rows)
            const quizRows = document.querySelectorAll('#quizTable .quiz-row');
            quizRows.forEach(row => {
                row.style.display = '';
            });
            
            // Hide all question rows
            const questionRows = document.querySelectorAll('[id^="questions-"]');
            questionRows.forEach(row => {
                row.style.display = 'none';
            });
            
            // Reset chevron icons
            const chevrons = document.querySelectorAll('[id^="chevron-"]');
            chevrons.forEach(chevron => {
                chevron.className = 'bi bi-chevron-down text-muted';
            });
            
            // Update stats
            updateQuizStats();
            
            // Restore button
            refreshBtn.innerHTML = originalHtml;
            refreshBtn.disabled = false;
            
            showAlert('Quiz data refreshed successfully!', 'success');
        }, 1500);
    }

    // Export results
    function exportResults() {
        const quizRows = document.querySelectorAll('#quizTable .quiz-row');
        const visibleRows = Array.from(quizRows).filter(row => row.style.display !== 'none');
        
        if (visibleRows.length === 0) {
            showAlert('No quiz data to export', 'warning');
            return;
        }
        
        // Create CSV content for quizzes
        let csvContent = 'Quiz ID,Title,Questions,Course,Created Date,Status\n';
        
        visibleRows.forEach(row => {
            const quizId = row.getAttribute('data-quiz-id') || '';
            const title = row.querySelector('td:nth-child(1) strong')?.textContent?.trim() || '';
            const questions = row.querySelector('td:nth-child(2) span')?.textContent?.trim() || '';
            const course = row.querySelector('td:nth-child(3) span')?.textContent?.trim() || 'No Course';
            const date = row.querySelector('td:nth-child(4)')?.textContent?.trim() || '';
            const status = 'Active'; // All quizzes are active
            
            // Clean up the data
            const cleanTitle = title.replace(/"/g, '""');
            const cleanQuestions = questions.replace(/"/g, '""');
            const cleanCourse = course.replace(/"/g, '""');
            
            csvContent += `"${quizId}","${cleanTitle}","${cleanQuestions}","${cleanCourse}","${date}","${status}"\n`;
        });
        
        // Download CSV
        const blob = new Blob([csvContent], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
