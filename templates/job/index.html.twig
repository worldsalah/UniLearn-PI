{% extends 'front_base.html.twig' %}

{% block title %}Jobs - Unilearn Marketplace{% endblock %}

{% block body %}

<!-- =======================
Page banner START -->
<section class="bg-primary bg-opacity-10 pt-4 pb-5">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1 class="display-5 fw-bold mb-3">Browse Jobs</h1>
                <p class="lead mb-4">Find the perfect job opportunity that matches your skills</p>
                
                <!-- Search and Filter -->
                <form class="bg-white rounded-3 p-3 shadow-sm">
                    <div class="row g-3 align-items-center">
                        <div class="col-md-4">
                            <input type="text" class="form-control border-0" placeholder="Search jobs..." value="{{ search }}">
                        </div>
                        <div class="col-md-2">
                            <select class="form-select border-0">
                                <option selected>All Categories</option>
                                <option>Programming</option>
                                <option>Design</option>
                                <option>Marketing</option>
                                <option>Business</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select border-0">
                                <option selected>Any Budget</option>
                                <option>$0 - $100</option>
                                <option>$100 - $500</option>
                                <option>$500 - $1000</option>
                                <option>$1000+</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select class="form-select border-0">
                                <option selected>All Status</option>
                                <option>Open</option>
                                <option>In Progress</option>
                                <option>Completed</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Search</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
<!-- =======================
Page banner END -->

<!-- =======================
Jobs listing START -->
<section class="py-5">
    <div class="container">
        <div class="row">
            <!-- Main content START -->
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4>{{ jobs|length }} Jobs Found</h4>
                    <div class="btn-group">
                        <button class="btn btn-outline-primary active">Latest</button>
                        <button class="btn btn-outline-primary">Popular</button>
                        <button class="btn btn-outline-primary">Price: Low to High</button>
                        <button class="btn btn-outline-primary">Price: High to Low</button>
                    </div>
                </div>

                <!-- Job cards -->
                <div class="row g-4">
                    {% for job in jobs %}
                    <div class="col-12">
                        <div class="card card-hover border-0 shadow-sm">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-md-8">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h5 class="card-title mb-1">{{ job.title }}</h5>
                                                <p class="text-muted small mb-2">
                                                    <i class="fas fa-user me-1"></i> {{ job.client.email }}
                                                    <span class="mx-2">•</span>
                                                    <i class="fas fa-calendar me-1"></i> {{ job.createdAt|date('M d, Y') }}
                                                </p>
                                            </div>
                                            <span class="badge bg-success">Open</span>
                                        </div>
                                        <p class="card-text">{{ job.description|slice(0, 150) }}...</p>
                                        <div class="d-flex flex-wrap gap-2 mb-3">
                                            {% if job.skills %}
                                                {% for skill in job.skills|split(',') %}
                                                    <span class="badge bg-light text-dark">{{ skill|trim }}</span>
                                                {% endfor %}
                                            {% endif %}
                                        </div>
                                        <div class="d-flex align-items-center">
                                            <span class="text-primary fw-bold me-3">${{ job.budget }}</span>
                                            <span class="text-muted small">
                                                <i class="fas fa-users me-1"></i> {{ job.applicationCount ?: 0 }} applications
                                            </span>
                                        </div>
                                    </div>
                                    <div class="col-md-4 text-md-end">
                                        {% if app.user %}
                                            <a href="{{ path('app_job_show', {id: job.id}) }}" class="btn btn-outline-primary btn-sm mb-2">View Details</a>
                                            <a href="{{ path('app_job_apply', {id: job.id}) }}" class="btn btn-primary btn-sm mb-2">Apply Now</a>
                                        {% else %}
                                            <a href="{{ path('app_login') }}" class="btn btn-primary btn-sm mb-2">Login to Apply</a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="col-12">
                        <div class="text-center py-5">
                            <i class="fas fa-briefcase fa-3x text-muted mb-3"></i>
                            <h4>No jobs found</h4>
                            <p class="text-muted">Try adjusting your search criteria</p>
                        </div>
                    </div>
                    {% endfor %}
                </div>

                <!-- Pagination -->
                {% if jobs|length > 0 %}
                <nav class="d-flex justify-content-center mt-5">
                    <ul class="pagination">
                        <li class="page-item disabled">
                            <a class="page-link" href="#" tabindex="-1">Previous</a>
                        </li>
                        <li class="page-item active"><a class="page-link" href="#">1</a></li>
                        <li class="page-item"><a class="page-link" href="#">2</a></li>
                        <li class="page-item"><a class="page-link" href="#">3</a></li>
                        <li class="page-item">
                            <a class="page-link" href="#">Next</a>
                        </li>
                    </ul>
                </nav>
                {% endif %}
            </div>
            <!-- Main content END -->

            <!-- Sidebar START -->
            <div class="col-lg-4">
                <!-- Post a Job Card -->
                <div class="card border-0 bg-primary bg-opacity-10 mb-4">
                    <div class="card-body text-center">
                        <i class="fas fa-plus-circle fa-3x text-primary mb-3"></i>
                        <h5 class="card-title">Post a Job</h5>
                        <p class="card-text">Get the best talent for your project</p>
                        <a href="{{ path('app_job_new') }}" class="btn btn-primary">Post Job</a>
                    </div>
                </div>

                <!-- Categories -->
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white">
                        <h6 class="card-title mb-0">Categories</h6>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Programming</span>
                                    <span class="badge bg-primary rounded-pill">45</span>
                                </div>
                            </a>
                            <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Design</span>
                                    <span class="badge bg-primary rounded-pill">32</span>
                                </div>
                            </a>
                            <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Marketing</span>
                                    <span class="badge bg-primary rounded-pill">28</span>
                                </div>
                            </a>
                            <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>Business</span>
                                    <span class="badge bg-primary rounded-pill">19</span>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Popular Skills -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white">
                        <h6 class="card-title mb-0">Popular Skills</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge bg-light text-dark">JavaScript</span>
                            <span class="badge bg-light text-dark">Python</span>
                            <span class="badge bg-light text-dark">React</span>
                            <span class="badge bg-light text-dark">UI/UX</span>
                            <span class="badge bg-light text-dark">Node.js</span>
                            <span class="badge bg-light text-dark">CSS</span>
                            <span class="badge bg-light text-dark">PHP</span>
                            <span class="badge bg-light text-dark">Marketing</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Sidebar END -->
        </div>
    </div>
</section>
<!-- =======================
Jobs listing END -->

{% endblock %}
