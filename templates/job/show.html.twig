{% extends 'front_base.html.twig' %}

{% block title %}{{ job.title }} - Job Request{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-briefcase me-2"></i>{{ job.title }}
                    </h4>
                    <div>
                        {% if job.status == 'open' %}
                            <span class="badge bg-success">📋 Open</span>
                        {% elseif job.status == 'assigned' %}
                            <span class="badge bg-warning">🔄 In Progress</span>
                        {% else %}
                            <span class="badge bg-secondary">✅ Closed</span>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Category</h6>
                            <p class="mb-3"><strong>{{ job.category|default('other')|title }}</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Budget</h6>
                            <p class="mb-3"><strong class="text-success">${{ job.budget ?? 0 }}</strong></p>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <h6 class="text-muted">Description</h6>
                        <div class="bg-light p-3 rounded">
                            <p class="mb-0">{{ job.description|nl2br }}</p>
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Posted</h6>
                            <p class="mb-3">{{ job.createdAt|date('M d, Y') }}</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Client</h6>
                            <p class="mb-3">{{ job.client.email }}</p>
                        </div>
                    </div>
                    
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_job_edit', {id: job.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Update Job
                        </a>
                        <form method="post" action="{{ path('app_job_delete', {id: job.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.id) }}">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this job request?')">
                                <i class="bi bi-trash me-1"></i>Delete Job
                            </button>
                        </form>
                        <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back to Marketplace
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>Job Details
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Status</h6>
                        <p class="mb-0">
                            {% if job.status == 'open' %}
                                <span class="badge bg-success">📋 Open</span>
                            {% elseif job.status == 'assigned' %}
                                <span class="badge bg-warning">🔄 In Progress</span>
                            {% else %}
                                <span class="badge bg-secondary">✅ Closed</span>
                            {% endif %}
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Category</h6>
                        <p class="mb-0">{{ job.category|default('other')|title }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Budget</h6>
                        <p class="mb-0 text-success fw-bold">${{ job.budget ?? 0 }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Posted Date</h6>
                        <p class="mb-0">{{ job.createdAt|date('F d, Y') }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Job ID</h6>
                        <p class="mb-0">#{{ job.id }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
