<!-- =======================
Main Banner END -->

<!-- Page content START -->
<section class="pt-0">
	<div class="container">
		<div class="row">
			<!-- Main content START -->
			<div class="col-xl-9 col-lg-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fs-3 mb-0">Latest Services</h2>
            </div>

            <!-- Filters -->
            <form method="get" class="row g-2 align-items-end mb-4">
                <div class="col-md-4">
                    <label class="form-label small text-muted">Keywords</label>
                    <input type="text" name="q" class="form-control" placeholder="Search services..." value="{{ app.request.query.get('q') }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Category</label>
                    <select name="category" class="form-select">
                        <option value="">All categories</option>
                        {% for category in categories %}
                            <option value="{{ category }}" {% if app.request.query.get('category') == category %}selected{% endif %}>{{ category }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Min price</label>
                    <input type="number" step="0.01" min="0" name="minPrice" class="form-control" value="{{ app.request.query.get('minPrice') }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-muted">Max price</label>
                    <input type="number" step="0.01" min="0" name="maxPrice" class="form-control" value="{{ app.request.query.get('maxPrice') }}">
                </div>
                <div class="col-md-1 d-grid">
                    <button class="btn btn-primary" type="submit">Filter</button>
                </div>
            </form>

            <!-- Services Grid -->
            <div class="row g-4">
                {% for product in products %}
                    <div class="col-md-6 col-lg-6 col-xl-4">
                        <div class="card shadow h-100 border-0 hover-lift">
                            <!-- Image -->
                            {% set productImage = vich_uploader_asset(product, 'imageFile') %}
                            {% if productImage %}
                                <img src="{{ productImage }}" class="card-img-top" alt="{{ product.title }}" style="height: 200px; object-fit: cover;">
                            {% else %}
                                <img src="{{ asset('assets/images/courses/4by3/01.jpg') }}" class="card-img-top" alt="{{ product.title }}" style="height: 200px; object-fit: cover;">
                            {% endif %}
                            
                            <!-- Card body -->
                            <div class="card-body pb-0">
                                <!-- Badge and favorite -->
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="badge bg-primary bg-opacity-10 text-primary">{{ product.category }}</span>
                                    <a href="#" class="h6 mb-0"><i class="far fa-heart"></i></a>
                                </div>
                                <!-- Title -->
                                <h5 class="card-title fw-normal"><a href="{{ path('app_product_show', {slug: product.slug}) }}" class="text-dark text-decoration-none">{{ product.title }}</a></h5>
                                <p class="card-text text-muted small text-truncate-2">{{ product.description|slice(0, 80) }}...</p>
                                
                                <!-- Rating -->
                                {% set rating = product.freelancer.rating ?? 0 %}
                                <ul class="list-inline mb-0">
                                    {% for i in 1..5 %}
                                        <li class="list-inline-item me-0 small">
                                            <i class="fas fa-star {% if i <= rating %}text-warning{% else %}text-muted{% endif %}"></i>
                                        </li>
                                    {% endfor %}
                                    <li class="list-inline-item ms-2 h6 fw-light mb-0">{{ rating|number_format(1) }}</li>
                                </ul>
                            </div>
                            
                            <!-- Card footer -->
                            <div class="card-footer pt-0 pb-3">
                                <hr>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-xs">
                                            <div class="avatar-img rounded-circle bg-primary"><span class="text-white position-absolute top-50 start-50 translate-middle">{{ product.freelancer.fullName|first }}</span></div>
                                        </div>
                                        <span class="h6 fw-light mb-0 ms-2 small">
                                            <a href="{{ path('app_student_show', {id: product.freelancer.id}) }}" class="text-decoration-none text-dark">
                                                {{ product.freelancer.fullName }}
                                            </a>
                                        </span>
                                    </div>
                                    <h5 class="text-success mb-0">{{ product.price }} $</h5>
                                </div>
                                <a href="{{ path('app_product_show', {slug: product.slug}) }}" class="btn btn-sm btn-primary-soft w-100 mt-2">View Details</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-5">
                         <div class="bg-light p-4 rounded-3">
                            <i class="bi bi-search fs-1 text-muted"></i>
                            <h4 class="mt-3">No services found</h4>
                            <p class="text-muted">Try adjusting your search criteria or clear filters.</p>
                            <a href="{{ path('app_marketplace_index') }}" class="btn btn-primary-soft">Clear Filters</a>
                         </div>
                    </div>
                {% endfor %}
            </div>

            <!-- Pagination -->
            <div class="d-flex justify-content-center mt-5">
                {{ knp_pagination_render(products) }}
            </div>

			</div>
			<!-- Main content END -->

			<!-- Right sidebar START -->
			<div class="col-xl-3 col-lg-4">
				<div class="row">
                    <div class="col-12">
                        <!-- Action Box -->
                        <div class="card bg-primary bg-opacity-10 mb-4 border-0">
                            <div class="card-body">
                                <h5 class="text-primary">Got skills?</h5>
                                <p class="small">Earn money by sharing your expertise with others.</p>
                                <a href="{{ path('app_product_new') }}" class="btn btn-sm btn-primary w-100 mb-2">Post a Service</a>
                                <a href="{{ path('app_freelancer_register') }}" class="btn btn-sm btn-dark w-100">Become a Freelancer</a>
                            </div>
                        </div>

                        <div class="card border mb-4">
                           <div class="card-header border-bottom bg-light">
                                <h5 class="card-header-title mb-0">Recent Job Requests</h5>
                           </div> 
                           <div class="card-body">
                                {% for job in jobs %}
                                    <div class="mb-3">
                                        <h6 class="mb-1"><a href="#" class="text-dark">{{ job.title }}</a></h6>
                                        <div class="d-flex justify-content-between">
                                            <small class="text-success fw-bold">{{ job.budget }} $</small>
                                            <small class="text-muted">{{ job.createdAt|date('d M') }}</small>
                                        </div>
                                    </div>
                                    {% if not loop.last %}<hr>{% endif %}
                                {% else %}
                                    <p class="text-muted small">No jobs posted yet.</p>
                                {% endfor %}
                                <div class="d-grid mt-3">
                                    <a href="{{ path('app_job_new') }}" class="btn btn-outline-primary btn-sm">Post a Job</a>
                                </div>
                           </div>
                        </div>
                    </div>
                </div>
			</div>
			<!-- Right sidebar END -->

		</div><!-- Row END -->
	</div>
</section>
<!-- Page content END -->
{% include 'components/footer.html.twig' %}
{% endblock %}
