{% extends 'admin/admin_base.html.twig' %}

{% block title %}Marketplace - Unilearn{% endblock %}

{% block admin_content %}

<!-- Title -->
<div class="row mb-4">
    <div class="col-12 d-sm-flex justify-content-between align-items-center">
        <h1 class="h3 mb-2 mb-sm-0">Marketplace Overview</h1>
        <a href="{{ path('app_job_new') }}" class="btn btn-primary-soft mb-0"><i class="fas fa-plus me-2"></i>Post a Job Request</a>
    </div>
</div>

<!-- Charts START -->
<div class="row g-4 mb-4">
    <!-- Category Distribution Chart -->
    <div class="col-lg-6">
        <div class="card shadow h-100">
            <div class="card-header border-bottom">
                <h5 class="card-header-title">Service Categories</h5>
            </div>
            <div class="card-body">
                <div id="categoryChart"></div>
            </div>
        </div>
    </div>

    <!-- Revenue Trend Chart -->
    <div class="col-lg-6">
        <div class="card shadow h-100">
            <div class="card-header border-bottom">
                <h5 class="card-header-title">Weekly Revenue Trend ($)</h5>
            </div>
            <div class="card-body">
                <div id="revenueChart"></div>
            </div>
        </div>
    </div>
</div>
<!-- Charts END -->

<!-- Counter boxes START -->
<div class="row g-4 mb-4">
    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-warning bg-opacity-15 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ stats.students }}</h2>
                    <span class="mb-0 h6 fw-light">Freelancers</span>
                </div>
                <div class="icon-lg rounded-circle bg-warning text-white mb-0"><i class="fas fa-user-graduate fa-fw"></i></div>
            </div>
        </div>
    </div>

    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-purple bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ stats.products }}</h2>
                    <span class="mb-0 h6 fw-light">Services</span>
                </div>
                <div class="icon-lg rounded-circle bg-purple text-white mb-0"><i class="fas fa-tv fa-fw"></i></div>
            </div>
        </div>
    </div>

    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-primary bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-0 fw-bold">{{ stats.jobs }}</h2>
                    <span class="mb-0 h6 fw-light">Job Requests</span>
                </div>
                <div class="icon-lg rounded-circle bg-primary text-white mb-0"><i class="fas fa-briefcase fa-fw"></i></div>
            </div>
        </div>
    </div>

    <!-- Counter item -->
    <div class="col-md-6 col-xxl-3">
        <div class="card card-body bg-success bg-opacity-10 p-4 h-100">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="d-flex">
                        <h2 class="mb-0 fw-bold">{{ stats.revenue|number_format(2) }}</h2>
                        <span class="mb-0 h2 ms-1">$</span>
                    </div>
                    <span class="mb-0 h6 fw-light">Weekly Revenue</span>
                </div>
                <div class="icon-lg rounded-circle bg-success text-white mb-0"><i class="bi bi-currency-dollar fa-fw"></i></div>
            </div>
        </div>
    </div>
</div>
<!-- Counter boxes END -->

<div class="row g-4">
    <!-- Main content START -->
    <div class="col-xl-9">
        
        <!-- Search and Filter START -->
        <div class="card shadow mb-4">
            <div class="card-body p-3">
                <form class="row g-3" method="get">
                    <div class="col-md-3">
                        <input class="form-control" type="search" name="q" placeholder="Search services..." value="{{ app.request.query.get('q') }}">
                    </div>
                    <div class="col-md-2">
                        <select class="form-select js-choice" name="category" onchange="this.form.submit()">
                            <option value="">All Categories</option>
                            {% for cat in categories %}
                                <option value="{{ cat }}" {% if app.request.query.get('category') == cat %}selected{% endif %}>{{ cat }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-2">
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" name="minPrice" placeholder="Min" value="{{ app.request.query.get('minPrice') }}">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" name="maxPrice" placeholder="Max" value="{{ app.request.query.get('maxPrice') }}">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <select class="form-select js-choice" name="sortBy" onchange="this.form.submit()">
                            <option value="newest" {% if app.request.query.get('sortBy') == 'newest' %}selected{% endif %}>Newest First</option>
                            <option value="az" {% if app.request.query.get('sortBy') == 'az' %}selected{% endif %}>Alphabetical (A-Z)</option>
                            <option value="za" {% if app.request.query.get('sortBy') == 'za' %}selected{% endif %}>Alphabetical (Z-A)</option>
                            <option value="price_asc" {% if app.request.query.get('sortBy') == 'price_asc' %}selected{% endif %}>Price (Low to High)</option>
                            <option value="price_desc" {% if app.request.query.get('sortBy') == 'price_desc' %}selected{% endif %}>Price (High to Low)</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-primary w-100 mb-0 px-2"><i class="fas fa-search"></i></button>
                    </div>
                </form>
            </div>
        </div>
        <!-- Search and Filter END -->

        <!-- Service Grid START -->
        <div class="row g-4">
            {% for product in products %}
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow h-100">
                        <!-- Image -->
                        <div class="position-relative">
                            {% set productImage = product.image ? asset('uploads/products/' ~ product.image) : null %}
                            {% if productImage %}
                                <img src="{{ productImage }}" class="card-img-top" alt="{{ product.title }}" style="height: 150px; object-fit: cover;">
                            {% else %}
                                <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 150px;">
                                    <i class="fas fa-image fa-2x text-muted opacity-25"></i>
                                </div>
                            {% endif %}
                            <div class="card-img-overlay d-flex z-index-0 p-2">
                                <div class="w-100 mb-auto d-flex justify-content-end">
                                    <div class="icon-sm bg-white rounded-circle fs-6 shadow">
                                        <a href="#" class="text-danger"><i class="far fa-heart"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Card body -->
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="badge bg-purple bg-opacity-10 text-purple small">{{ product.category }}</span>
                                <span class="h6 fw-light mb-0 small"><i class="fas fa-star text-warning me-1"></i>{{ product.freelancer.rating|default('0.0') }}</span>
                            </div>
                            <h6 class="card-title fw-bold mb-1"><a href="{{ path('app_product_show', {slug: product.slug}) }}" class="text-dark">{{ product.title }}</a></h6>
                            <p class="text-muted small mb-2 text-truncate-2">{{ product.description|slice(0, 60) }}...</p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="h6 fw-bold mb-0 text-success">${{ product.price }}</span>
                                <a href="{{ path('app_order_new', {id: product.id}) }}" class="btn btn-sm btn-primary-soft mb-0">Order</a>
                            </div>
                        </div>
                        <!-- Card footer -->
                        {% if is_granted('ROLE_ADMIN') or (app.user and product.freelancer.user == app.user) %}
                        <div class="card-footer py-2 bg-light border-top">
                            <div class="d-flex justify-content-end">
                                <a href="{{ path('app_admin_product_edit', {id: product.id}) }}" class="btn btn-link btn-sm text-success p-0 mb-0 me-2" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                <form method="post" action="{{ path('app_product_delete', {slug: product.slug}) }}" onsubmit="return confirm('Are you sure?');" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.slug) }}">
                                    <button class="btn btn-link btn-sm text-danger p-0 mb-0" title="Delete"><i class="fas fa-trash"></i></button>
                                </form>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div class="col-12 text-center py-5">
                    <h5 class="text-muted">No services found.</h5>
                </div>
            {% endfor %}
        </div>
        <!-- Service Grid END -->

        <!-- Pagination START -->
        <div class="mt-4">
            {{ knp_pagination_render(products) }}
        </div>
        <!-- Pagination END -->

    </div>
    <!-- Main content END -->

    <!-- Right Sidebar START -->
    <div class="col-xl-3">
        <div class="card shadow p-4 mb-4">
            <h5 class="card-title mb-3">Active Job Requests</h5>
            <div class="list-group list-group-flush">
                {% for job in jobs %}
                    <div class="list-group-item px-0 py-3 bg-transparent">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="mb-0 fw-bold">{{ job.title }}</h6>
                            <span class="badge bg-success bg-opacity-10 text-success small">${{ job.budget }}</span>
                        </div>
                        <p class="text-muted small mb-2">{{ job.description|slice(0, 50) }}...</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted">{{ job.createdAt|date('M d') }}</span>
                            <div class="d-flex align-items-center">
                                <a href="#" class="btn btn-link btn-sm p-0 mb-0 text-primary fw-bold text-decoration-none small">Apply</a>
                                {% if is_granted('ROLE_ADMIN') or (app.user and job.client == app.user) %}
                                    <form method="post" action="{{ path('app_job_delete', {id: job.id}) }}" onsubmit="return confirm('Are you sure?');" class="d-inline ms-2">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.id) }}">
                                        <button class="btn btn-link btn-sm text-danger p-0 mb-0"><i class="fas fa-trash"></i></button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted small">No jobs open.</p>
                {% endfor %}
            </div>
            <hr>
            <a href="{{ path('app_job_new') }}" class="btn btn-outline-primary w-100 mb-0">Post Job</a>
        </div>
    </div>
    <!-- Right Sidebar END -->
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Category Distribution Chart
    var options1 = {
        series: {{ charts.counts|json_encode|raw }},
        chart: {
            height: 300,
            type: 'donut',
        },
        labels: {{ charts.categories|json_encode|raw }},
        legend: {
            position: 'bottom'
        },
        responsive: [{
            breakpoint: 480,
            options: {
                chart: {
                    width: 200
                },
                legend: {
                    position: 'bottom'
                }
            }
        }]
    };
    var chart1 = new ApexCharts(document.querySelector("#categoryChart"), options1);
    chart1.render();

    // Revenue Trend Chart
    var options2 = {
        series: [{
            name: 'Revenue',
            data: {{ charts.revenue|json_encode|raw }}
        }],
        chart: {
            height: 300,
            type: 'area',
            toolbar: {
                show: false
            }
        },
        dataLabels: {
            enabled: false
        },
        stroke: {
            curve: 'smooth'
        },
        xaxis: {
            categories: {{ charts.dates|json_encode|raw }},
        },
        tooltip: {
            x: {
                format: 'dd/MM/yy'
            },
        },
    };
    var chart2 = new ApexCharts(document.querySelector("#revenueChart"), options2);
    chart2.render();
</script>
{% endblock %}
