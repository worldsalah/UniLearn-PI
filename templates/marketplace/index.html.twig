					<li class="list-inline-item me-2"> <i class="bi bi-patch-check-fill h6 me-1"></i>Verified Freelancers</li>
					<li class="list-inline-item me-2"> <i class="bi bi-patch-check-fill h6 me-1"></i>Secure Payments</li>
					<li class="list-inline-item"> <i class="bi bi-patch-check-fill h6 me-1"></i>Quality Guaranteed</li>
				</ul>
