{% extends 'base.html.twig' %}

{% block title %}Marketplace - Unilearn{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}

<style>
    .marketplace-hero {
        background-color: #f8f9fa;
        padding: 60px 0;
    }
    .filter-bar {
        background: #fff;
        padding: 15px;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        margin-top: -30px;
        position: relative;
        z-index: 10;
    }
    .search-btn {
        background-color: #066ac9; /* Blue from screenshot */
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
    }
    .service-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    .service-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .service-card .card-img-top {
        height: 180px;
        object-fit: cover;
    }
    .heart-icon {
        position: absolute;
        top: 15px;
        right: 15px;
        color: #ff4d4d;
        background: #fff;
        width: 30px;
        height: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        z-index: 2;
    }
    .category-badge {
        background-color: #e6f7f5;
        color: #20c997;
        padding: 5px 12px;
        border-radius: 5px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }
    .location-info {
        color: #066ac9;
        font-size: 0.85rem;
    }
    .price-tag {
        font-weight: 700;
        color: #333;
    }
    .btn-hire {
        background-color: #e6f7f5;
        color: #20c997;
        border: none;
        padding: 8px 20px;
        border-radius: 5px;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .btn-view h6 {
        font-size: 0.85rem;
        margin: 0;
    }
    .btn-view {
        background-color: #e9ecef;
        color: #066ac9;
        border: none;
        padding: 8px 20px;
        border-radius: 5px;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
    }
    /* Dynamic background patterns for missing images */
    .pattern-tutor { background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); position: relative; }
    .pattern-dev { background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); position: relative; }
    .pattern-admin { background: linear-gradient(135deg, #fecaca 0%, #f9a8d4 100%); position: relative; }
    
    .vector-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        opacity: 0.2;
        background-image: radial-gradient(#fff 1px, transparent 1px);
        background-size: 20px 20px;
    }
    .hero-title {
        font-weight: 800;
        font-size: 2.5rem;
        color: #111;
    }
    .hero-subtitle {
        color: #666;
    }
</style>

<!-- Hero Section -->
<section class="marketplace-hero text-center">
    <div class="container">
        <h1 class="hero-title">Find your next opportunity</h1>
        <p class="hero-subtitle mb-5">Join our community of students, teachers, and administrators.</p>
    </div>
</section>

<!-- Filter Bar -->
<div class="container">
    <div class="filter-bar">
        <form method="get" class="row g-3 align-items-center">
            <div class="col-lg-3">
                <a href="{{ path('app_job_new') }}" class="btn btn-outline-primary w-100 py-2">
                    <i class="fas fa-plus me-2"></i> Post a Job
                </a>
            </div>
            <div class="col-lg-3">
                <select name="sort" class="form-select border-0 bg-light py-2">
                    <option value="">Sort by</option>
                    <option value="newest">Newest</option>
                    <option value="price_low">Price: Low to High</option>
                    <option value="price_high">Price: High to Low</option>
                </select>
            </div>
            <div class="col-lg-3">
                <select name="category" class="form-select border-0 bg-light py-2">
                    <option value="">Category</option>
                    {% for cat in categories %}
                        <option value="{{ cat }}" {% if app.request.query.get('category') == cat %}selected{% endif %}>{{ cat }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-lg-3">
                <div class="input-group">
                    <input type="text" name="q" class="form-control border-0 bg-light py-2" placeholder="Search..." value="{{ app.request.query.get('q') }}">
                    <button class="search-btn px-4" type="submit">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Main Content -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Services Grid -->
            <div class="col-lg-8">
                <div class="row g-4">
                    {% for product in products %}
                        <div class="col-md-6">
                            <div class="service-card position-relative">
                                <a href="#" class="heart-icon">
                                    <i class="far fa-heart"></i>
                                </a>
                                
                                <!-- Header / Image -->
                                <div class="position-relative">
                                    {% set productImage = product.image ? asset('uploads/products/' ~ product.image) : null %}
                                    {% if productImage %}
                                        <img src="{{ productImage }}" class="card-img-top" alt="{{ product.title }}">
                                    {% else %}
                                        <div class="card-img-top d-flex align-items-center justify-content-center {% if 'Tutor' in product.category %}pattern-tutor{% elseif 'Web' in product.category %}pattern-dev{% else %}pattern-admin{% endif %}">
                                            <div class="vector-overlay"></div>
                                            {% if 'Tutor' in product.category %}
                                                <i class="fas fa-chevron-right fa-5x text-white opacity-25"></i>
                                            {% elseif 'Web' in product.category or 'Dev' in product.category %}
                                                <div class="border border-info p-3 text-info fw-bold display-6">Ps</div>
                                            {% else %}
                                                <i class="fab fa-figma fa-5x text-white opacity-50"></i>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>

                                <!-- Body -->
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="category-badge">{{ product.category }}</span>
                                        <div class="text-warning small">
                                            <i class="fas fa-star"></i> {{ product.freelancer.rating|default('0.0') }}
                                        </div>
                                    </div>
                                    <h5 class="card-title fw-bold mb-2">
                                        <a href="{{ path('app_product_show', {slug: product.slug}) }}" class="text-dark text-decoration-none">{{ product.title }}</a>
                                    </h5>
                                    <p class="text-muted small mb-4">{{ product.description|slice(0, 80) }}...</p>
                                    
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <span class="location-info">
                                            <i class="fas fa-user me-1 text-muted"></i> {{ product.freelancer.fullName }}
                                        </span>
                                        <span class="price-tag">${{ product.price }}</span>
                                    </div>

                                    <div class="d-flex justify-content-between pt-3 border-top">
                                        <a href="{{ path('app_order_new', {id: product.id}) }}" class="btn-hire text-decoration-none">Order Now</a>
                                        <a href="{{ path('app_student_show', {id: product.freelancer.id}) }}" class="btn-view">Profile</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="col-12 text-center py-5">
                            <h3 class="text-muted">No services found.</h3>
                        </div>
                    {% endfor %}
                </div>

                <!-- Pagination -->
                <div class="d-flex justify-content-center mt-5">
                    {{ knp_pagination_render(products) }}
                </div>
            </div>

            <!-- Job Sidebar -->
            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-3 p-4 bg-light mb-4">
                    <h5 class="fw-bold mb-3">Latest Job Offers</h5>
                    <div class="list-group list-group-flush bg-transparent">
                        {% for job in jobs %}
                            <div class="list-group-item bg-transparent border-0 px-0 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="mb-0 fw-bold">{{ job.title }}</h6>
                                    <span class="badge bg-success-soft text-success small">${{ job.budget }}</span>
                                </div>
                                <p class="text-muted small mb-1">{{ job.description|slice(0, 60) }}...</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="small text-muted"><i class="far fa-clock me-1"></i> {{ job.createdAt|date('M d') }}</span>
                                    <a href="#" class="btn btn-link btn-sm p-0 text-primary text-decoration-none fw-bold">Apply Now</a>
                                </div>
                            </div>
                        {% else %}
                            <p class="text-muted small">No jobs posted recently.</p>
                        {% endfor %}
                    </div>
                    <hr>
                    <a href="{{ path('app_job_new') }}" class="btn btn-primary w-100 py-2">
                        <i class="fas fa-paper-plane me-2"></i> Post a Job Request
                    </a>
                </div>

                <!-- Statistics Snippet -->
                <div class="card shadow-sm border-0 rounded-3 p-4 bg-primary text-white">
                    <h6 class="text-white-50 mb-1">Total Freelancers</h6>
                    <h3 class="text-white fw-bold mb-3">1,240+</h3>
                    <h6 class="text-white-50 mb-1">Completed Orders</h6>
                    <h3 class="text-white fw-bold">4,800+</h3>
                </div>
            </div>
        </div>
    </div>
</section>

{% include 'components/footer.html.twig' %}
{% endblock %}
