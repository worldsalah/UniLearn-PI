{% extends 'front_base.html.twig' %}

{% block title %}Edit Order - {{ order.id }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil me-2"></i>Edit Order #{{ order.id }}
                    </h4>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                    
                    <div class="row g-3">
                        <div class="col-12">
                            {{ form_row(form.status) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.totalPrice) }}
                        </div>
                        <div class="col-12">
                            <div class="d-flex justify-content-between">
                                <a href="{{ path('app_order_show', {id: order.id}) }}" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left me-1"></i>Back to Order
                                </a>
                                <button type="submit" class="btn btn-warning">
                                    <i class="bi bi-check me-1"></i>Update Order
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
