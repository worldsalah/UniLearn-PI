{% extends 'base.html.twig' %}

{% block title %}Confirm Order - Marketplace{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}
<section class="py-5">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-lg-6">
                <div class="card border-0 shadow-sm p-4 p-sm-5 text-center">
                    <div class="icon-lg bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-4">
                        <i class="fas fa-shopping-cart fa-lg"></i>
                    </div>
                    
                    <h2 class="fw-bold mb-2">Confirm Your Order</h2>
                    <p class="text-muted mb-4">You're just one step away from starting your project with {{ product.freelancer.fullName }}.</p>
                    
                    <div class="bg-light rounded-3 p-4 mb-4">
                        <h5 class="fw-bold mb-1">{{ product.title }}</h5>
                        <p class="text-muted small mb-3">Service Category: {{ product.category }}</p>
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="h6 mb-0">Total Amount:</span>
                            <span class="h4 mb-0 text-primary">${{ order.totalPrice|number_format(2) }}</span>
                        </div>
                    </div>
                    
                    {{ form_start(form) }}
                        <div class="alert alert-info border-0 shadow-sm small mb-4">
                            <i class="fas fa-info-circle me-2"></i>
                            For this demonstration, the payment process is simulated. Clicking the button below will finalize your order instantly.
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-lg btn-primary py-3 fw-bold">
                                <i class="fas fa-check-circle me-2"></i>Confirm & Pay Now
                            </button>
                            <a href="{{ path('app_product_show', {slug: product.slug}) }}" class="btn btn-link text-muted">Cancel and return</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% include 'components/footer.html.twig' %}
{% endblock %}
