{% extends 'base.html.twig' %}

{% block title %}Confirm Order - Marketplace{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}
<section class="py-5">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-lg-6">
                <div class="card shadow p-4 text-center">
                    <h3 class="mb-4">Confirm Your Order</h3>
                    
                    <div class="mb-4">
                        <h5>{{ product.title }}</h5>
                        <p class="text-muted">By {{ product.freelancer.fullName }}</p>
                    </div>
                    
                    <h2 class="text-success mb-4">{{ order.totalPrice }} $</h2>
                    
                    {{ form_start(form) }}
                        <!-- Payment details would go here -->
                        <div class="alert alert-light border">
                            Payment will be simulated for this demo.
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-lg btn-success">Pay & Order</button>
                            <a href="{{ path('app_product_show', {slug: product.slug}) }}" class="btn btn-light">Cancel</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</section>
{% include 'components/footer.html.twig' %}
{% endblock %}
