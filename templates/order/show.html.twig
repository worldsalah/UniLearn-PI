{% extends 'front_base.html.twig' %}

{% block title %}{{ order.id }} - Order Details{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <i class="bi bi-cart me-2"></i>Order #{{ order.id }}
                    </h4>
                    <div>
                        {% if order.status == 'pending' %}
                            <span class="badge bg-warning">⏳ Pending</span>
                        {% elseif order.status == 'processing' %}
                            <span class="badge bg-info">🔄 Processing</span>
                        {% elseif order.status == 'completed' %}
                            <span class="badge bg-success">✅ Completed</span>
                        {% else %}
                            <span class="badge bg-danger">❌ Cancelled</span>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Status</h6>
                            <p class="mb-3">
                                {% if order.status == 'pending' %}
                                    <span class="badge bg-warning">⏳ Pending</span>
                                {% elseif order.status == 'processing' %}
                                    <span class="badge bg-info">🔄 Processing</span>
                                {% elseif order.status == 'completed' %}
                                    <span class="badge bg-success">✅ Completed</span>
                                {% else %}
                                    <span class="badge bg-danger">❌ Cancelled</span>
                                {% endif %}
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Total Price</h6>
                            <p class="mb-3"><strong class="text-success">${{ order.totalPrice }}</strong></p>
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted">Order Date</h6>
                            <p class="mb-3">{{ order.createdAt|date('M d, Y') }}</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Buyer</h6>
                            <p class="mb-3">{{ order.buyer.email }}</p>
                        </div>
                    </div>
                    
                    {% if order.product %}
                    <div class="mb-4">
                        <h6 class="text-muted">Product</h6>
                        <div class="bg-light p-3 rounded">
                            <p class="mb-0"><strong>{{ order.product.title }}</strong></p>
                            <p class="mb-0 text-muted">{{ order.product.description|slice(0, 100) }}...</p>
                        </div>
                    </div>
                    {% endif %}
                    
                    {% if order.rating %}
                    <div class="mb-4">
                        <h6 class="text-muted">Rating</h6>
                        <div class="bg-light p-3 rounded">
                            <p class="mb-0">
                                {% for i in 1..5 %}
                                    {% if i <= order.rating %}
                                        <i class="bi bi-star-fill text-warning"></i>
                                    {% else %}
                                        <i class="bi bi-star text-muted"></i>
                                    {% endif %}
                                {% endfor %}
                                ({{ order.rating }}/5)
                            </p>
                        </div>
                    </div>
                    {% endif %}
                    
                    {% if order.review %}
                    <div class="mb-4">
                        <h6 class="text-muted">Review</h6>
                        <div class="bg-light p-3 rounded">
                            <p class="mb-0">{{ order.review }}</p>
                        </div>
                    </div>
                    {% endif %}
                    
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_order_edit', {id: order.id}) }}" class="btn btn-warning">
                            <i class="bi bi-pencil me-1"></i>Update Order
                        </a>
                        <form method="post" action="{{ path('app_order_delete', {id: order.id}) }}" style="display: inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this order?')">
                                <i class="bi bi-trash me-1"></i>Delete Order
                            </button>
                        </form>
                        <a href="{{ path('app_marketplace_index') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back to Marketplace
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>Order Details
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Order ID</h6>
                        <p class="mb-0">#{{ order.id }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Status</h6>
                        <p class="mb-0">
                            {% if order.status == 'pending' %}
                                <span class="badge bg-warning">⏳ Pending</span>
                            {% elseif order.status == 'processing' %}
                                <span class="badge bg-info">🔄 Processing</span>
                            {% elseif order.status == 'completed' %}
                                <span class="badge bg-success">✅ Completed</span>
                            {% else %}
                                <span class="badge bg-danger">❌ Cancelled</span>
                            {% endif %}
                        </p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Total Price</h6>
                        <p class="mb-0 text-success fw-bold">${{ order.totalPrice }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Order Date</h6>
                        <p class="mb-0">{{ order.createdAt|date('F d, Y') }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted">Buyer</h6>
                        <p class="mb-0">{{ order.buyer.email }}</p>
                    </div>
                    
                    {% if order.product %}
                    <div class="mb-3">
                        <h6 class="text-muted">Product</h6>
                        <p class="mb-0">{{ order.product.title }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
