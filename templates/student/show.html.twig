{% extends 'base.html.twig' %}

{% block title %}{{ student.fullName }} - Profile{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}
<!-- Page content START -->
<section class="pt-5 pb-0">
	<div class="container">
		<div class="row g-0 g-lg-5">
            <!-- Left sidebar START -->
            <div class="col-lg-4">
                <div class="card shadow border-0 p-4 mb-4 text-center">
                    <!-- Avatar -->
                    <div class="avatar avatar-xxl mb-3 mx-auto">
                        <img class="avatar-img rounded-circle border border-3 border-white shadow" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                    </div>
                    <h4 class="mb-0 fw-bold">{{ student.fullName }}</h4>
                    <p class="text-muted small mb-3">{{ student.user.email }}</p>
                    
                    <div class="bg-light rounded-3 p-3 mb-4">
                        <div class="row g-0">
                            <div class="col-6 border-end">
                                <h6 class="mb-0">{{ student.rating|number_format(1) }}</h6>
                                <p class="small mb-0 text-warning"><i class="fas fa-star me-1"></i>Rating</p>
                            </div>
                            <div class="col-6">
                                <h6 class="mb-0">{{ student.products|length }}</h6>
                                <p class="small mb-0 text-muted">Services</p>
                            </div>
                        </div>
                    </div>

                    <div class="text-start">
                        <h6 class="fw-bold mb-2">About me</h6>
                        <p class="small text-muted mb-4">{{ student.bio|default('No bio provided.') }}</p>
                        
                        <h6 class="fw-bold mb-2">Skills</h6>
                        <div class="d-flex flex-wrap gap-2">
                            {% if student.skills is iterable %}
                                {% for skill in student.skills %}
                                    <span class="badge bg-primary-soft text-primary small">{{ skill }}</span>
                                {% endfor %}
                            {% else %}
                                {% set skillsArray = student.skills|split(',') %}
                                {% for skill in skillsArray %}
                                    {% if skill|trim is not empty %}
                                        <span class="badge bg-primary-soft text-primary small">{{ skill|trim }}</span>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Right Content -->
            <div class="col-lg-8">
                <h3>Services by {{ student.fullName }}</h3>
                <div class="row g-4 mt-2">
                     {% for product in student.products %}
                        <div class="col-sm-6">
                            <div class="card shadow h-100">
                                {% set productImage = vich_uploader_asset(product, 'imageFile') %}
                                <img src="{{ productImage ?: asset('assets/images/courses/4by3/08.jpg') }}" class="card-img-top" alt="service">
                                <div class="card-body">
                                    <h5 class="card-title"><a href="{{ path('app_product_show', {slug: product.slug}) }}">{{ product.title }}</a></h5>
                                    <p class="text-primary fw-bold">{{ product.price }} $</p>
                                </div>
                            </div>
                        </div>
                     {% else %}
                        <div class="col-12"><p>No services published yet.</p></div>
                     {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>
{% include 'components/footer.html.twig' %}
{% endblock %}
