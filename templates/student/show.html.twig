{% extends 'base.html.twig' %}

{% block title %}{{ student.fullName }} - Profile{% endblock %}

{% block body %}
{% include 'components/header.html.twig' %}
<!-- Page content START -->
<section class="pt-5 pb-0">
	<div class="container">
		<div class="row g-0 g-lg-5">
			<!-- Left sidebar START -->
			<div class="col-lg-4">
				<div class="row">
					<div class="col-md-6 col-lg-12">
						<div class="card shadow p-4 mb-4">
                            <div class="text-center">
                                <!-- Avatar -->
                                <div class="avatar avatar-xl mb-3">
                                    <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="avatar">
                                </div>
                                <h4 class="mb-0">{{ student.fullName }}</h4>
                                <p class="text-muted">{{ student.user.email }}</p>
                                <div class="mt-2">
                                    <i class="fas fa-star text-warning"></i> {{ student.rating|number_format(1) }} / 5.0
                                </div>
                            </div>
                            <hr>
                            <h6>Bio</h6>
                            <p>{{ student.bio }}</p>
                            
                            <h6>Skills</h6>
                            <div class="d-flex flex-wrap gap-2">
                                {% for skill in student.skills %}
                                    <span class="badge bg-light text-dark">{{ skill }}</span>
                                {% else %}
                                    <span class="text-muted">No specific skills listed.</span>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Right Content -->
            <div class="col-lg-8">
                <h3>Services by {{ student.fullName }}</h3>
                <div class="row g-4 mt-2">
                     {% for product in student.products %}
                        <div class="col-sm-6">
                            <div class="card shadow h-100">
                                {% set productImage = vich_uploader_asset(product, 'imageFile') %}
                                <img src="{{ productImage ?: asset('assets/images/courses/4by3/08.jpg') }}" class="card-img-top" alt="service">
                                <div class="card-body">
                                    <h5 class="card-title"><a href="{{ path('app_product_show', {slug: product.slug}) }}">{{ product.title }}</a></h5>
                                    <p class="text-primary fw-bold">{{ product.price }} $</p>
                                </div>
                            </div>
                        </div>
                     {% else %}
                        <div class="col-12"><p>No services published yet.</p></div>
                     {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>
{% include 'components/footer.html.twig' %}
{% endblock %}
